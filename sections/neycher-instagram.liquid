<section
  class="neycher-instagram"
  style="
    --ig-bg: {{ section.settings.bg_color }};
    --ig-heading-color: {{ section.settings.heading_color }};
    --ig-handle-color: {{ section.settings.handle_color }};
    --ig-pt: {{ section.settings.padding_top }}px;
    --ig-pb: {{ section.settings.padding_bottom }}px;
    --ig-gap: {{ section.settings.gap }}px;
    --ig-radius: {{ section.settings.image_radius }}px;
  "
>
  <div class="neycher-instagram__header">
    <h2 class="n-title-section neycher-instagram__title">{{ section.settings.heading | escape }}</h2>
    <p class="neycher-instagram__handle">{{ section.settings.handle | escape }}</p>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="neycher-instagram__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == "ig_image" -%}
          <a
            href="{{ section.settings.instagram_url }}"
            target="_blank"
            rel="noopener"
            class="neycher-instagram__item"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: "lazy",
                  width: 300,
                  height: 300,
                  alt: section.settings.handle
              }}
            {%- elsif block.settings.image_asset != blank -%}
              <img
                src="{{ block.settings.image_asset | asset_url }}"
                alt="{{ section.settings.handle | escape }}"
                loading="lazy"
                width="300"
                height="300"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'neycher-instagram__placeholder' }}
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
.neycher-instagram {
  background-color: var(--ig-bg, #ffffff);
  padding: var(--ig-pt, 60px) 60px var(--ig-pb, 100px);
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-instagram__header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24px;
}
.neycher-instagram__title {
  margin: 0;
  color: var(--ig-heading-color, #1D2836);
}
.neycher-instagram__handle {
  font-family: var(--n-font);
  font-size: 14px;
  color: var(--ig-handle-color, #999999);
  margin: 0;
}
.neycher-instagram__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: var(--ig-gap, 12px);
}
.neycher-instagram__item {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: var(--ig-radius, 8px);
  display: block;
}
.neycher-instagram__item img,
.neycher-instagram__item svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.neycher-instagram__placeholder {
  width: 100%;
  height: 100%;
}
@media screen and (max-width: 749px) {
  .neycher-instagram {
    padding: 40px 16px var(--ig-pb, 60px);
  }
  .neycher-instagram__header {
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }
  .neycher-instagram__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Instagram",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Handle",
      "default": "@neycher"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL",
      "info": "e.g. https://www.instagram.com/tryneycher/"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1D2836"
    },
    {
      "type": "color",
      "id": "handle_color",
      "label": "Handle color",
      "default": "#999999"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "ig_image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Asset filename fallback",
          "info": "Asset filename fallback"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neycher Instagram",
      "blocks": [
        {
          "type": "ig_image",
          "settings": {
            "image_asset": "instagram-1.jpg"
          }
        },
        {
          "type": "ig_image",
          "settings": {
            "image_asset": "instagram-2.jpg"
          }
        },
        {
          "type": "ig_image",
          "settings": {
            "image_asset": "instagram-3.jpg"
          }
        },
        {
          "type": "ig_image",
          "settings": {
            "image_asset": "instagram-4.jpg"
          }
        },
        {
          "type": "ig_image",
          "settings": {
            "image_asset": "instagram-5.jpg"
          }
        }
      ]
    }
  ]
}
{% endschema %}
