{% stylesheet %}
.neycher-instagram {
  padding: 60px 60px 80px;
  max-width: 1440px;
  margin: 0 auto;
  text-align: center;
}
.neycher-instagram__title {
  font-family: "Open Sans", sans-serif;
  font-size: 18px;
  font-weight: 400;
  color: #000;
  margin: 0 0 4px;
}
.neycher-instagram__handle {
  font-family: "Open Sans", sans-serif;
  font-size: 14px;
  color: #777;
  margin: 0 0 24px;
}
.neycher-instagram__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
}
.neycher-instagram__item {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: 8px;
  display: block;
}
.neycher-instagram__item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
@media screen and (max-width: 749px) {
  .neycher-instagram {
    padding: 40px 16px 60px;
  }
  .neycher-instagram__grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Instagram",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Instagram"
    }
  ]
}
{% endschema %}
