<section class="neycher-hero">
  <div class="neycher-hero__media">
    <img src="{{ 'hero-bg.webp' | asset_url }}" alt="Neycher products" loading="eager" width="1440" height="900">
  </div>
  <div class="neycher-hero__overlay"></div>
  <div class="neycher-hero__content">
    <h1 class="neycher-hero__heading">Save up to 20%<br>with subscription</h1>
    <a href="/collections/all" class="neycher-hero__btn">Shop</a>
  </div>
</section>

{% stylesheet %}
.neycher-hero {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 500px;
  max-height: 900px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  justify-content: flex-start;
}
.neycher-hero__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.neycher-hero__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}
.neycher-hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(180deg, transparent 42%, rgba(139,158,177,0.5) 73%, rgba(139,158,177,0.7) 100%);
}
.neycher-hero__content {
  position: relative;
  z-index: 2;
  padding: 0 60px 80px;
  max-width: 600px;
}
.neycher-hero__heading {
  font-family: "Open Sans", sans-serif;
  font-size: 48px;
  font-weight: 300;
  line-height: 1.15;
  color: #000;
  margin: 0 0 28px;
  letter-spacing: -0.5px;
}
.neycher-hero__btn {
  display: inline-block;
  background: #000;
  color: #fff;
  font-family: "Open Sans", sans-serif;
  font-size: 15px;
  font-weight: 400;
  text-decoration: none;
  padding: 14px 72px;
  border-radius: 0;
  text-align: center;
  letter-spacing: 0.5px;
}
.neycher-hero__btn:hover {
  opacity: 0.85;
}
@media screen and (max-width: 749px) {
  .neycher-hero {
    height: 80vh;
    min-height: 400px;
    max-height: 600px;
  }
  .neycher-hero__content {
    padding: 0 20px 40px;
  }
  .neycher-hero__heading {
    font-size: 32px;
  }
  .neycher-hero__btn {
    padding: 12px 56px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Hero",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Hero"
    }
  ]
}
{% endschema %}
