<section class="neycher-hero">
  <div class="neycher-hero__media">
    <img src="{{ 'hero-bg.webp' | asset_url }}" alt="Neycher products" loading="eager" width="1440" height="900">
  </div>
  <div class="neycher-hero__content">
    <h1 class="neycher-hero__heading">Save up to 20%<br>with subscription</h1>
    <a href="/collections/all" class="neycher-hero__btn">Shop Now</a>
  </div>
</section>

{% stylesheet %}
.neycher-hero {
  position: relative;
  width: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}
.neycher-hero__media {
  width: 100%;
}
.neycher-hero__media img {
  width: 100%;
  height: auto;
  display: block;
}
.neycher-hero__content {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: 1;
  padding: 0 60px;
  max-width: 500px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}
.neycher-hero__heading {
  font-family: "Open Sans", sans-serif;
  font-size: 48px;
  font-weight: 300;
  line-height: 1.15;
  color: #fff;
  margin: 0 0 32px;
  letter-spacing: -0.5px;
}
.neycher-hero__btn {
  display: inline-block;
  background: #fff;
  color: #000;
  font-family: "Open Sans", sans-serif;
  font-size: 15px;
  font-weight: 500;
  text-decoration: none;
  padding: 16px 56px;
  border-radius: 0;
  text-align: center;
  letter-spacing: 0.3px;
}
.neycher-hero__btn:hover {
  opacity: 0.9;
}
@media screen and (max-width: 749px) {
  .neycher-hero__content {
    padding: 0 20px;
    max-width: 100%;
  }
  .neycher-hero__heading {
    font-size: 28px;
  }
  .neycher-hero__btn {
    padding: 14px 44px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Hero",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Hero"
    }
  ]
}
{% endschema %}
