<section class="neycher-hero" style="--hero-bg: {{ section.settings.bg_color }}; --hero-height: {{ section.settings.height }}vh; --hero-heading-size: {{ section.settings.heading_size }}px; --hero-heading-color: {{ section.settings.heading_color }}; --hero-btn-bg: {{ section.settings.button_bg }}; --hero-btn-color: {{ section.settings.button_color }}; --hero-pt: {{ section.settings.padding_top }}px; --hero-pb: {{ section.settings.padding_bottom }}px;">
  <div class="neycher-hero__media">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1920 }}" alt="{{ section.settings.heading | escape }}" loading="eager" width="1920" height="1080">
    {%- else -%}
      <img src="{{ 'hero-bg-3.jpeg' | asset_url }}" alt="{{ section.settings.heading | escape }}" loading="eager" width="1440" height="900">
    {%- endif -%}
  </div>
  <div class="neycher-hero__overlay"></div>
  <div class="neycher-hero__content">
    <h1 class="neycher-hero__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="neycher-hero__btn">{{ section.settings.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.neycher-hero {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: var(--hero-bg, #9AA7B6);
}
.neycher-hero__media {
  width: 100%;
}
.neycher-hero__media img {
  width: 120%;
  height: var(--hero-height, 85vh);
  display: block;
  object-fit: cover;
  object-position: center center;
  margin-left: auto;
  transform: translateX(16%);
}
.neycher-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    var(--hero-bg, rgba(154, 167, 182, 1)) 0%,
    color-mix(in srgb, var(--hero-bg, #9AA7B6) 85%, transparent) 15%,
    color-mix(in srgb, var(--hero-bg, #9AA7B6) 30%, transparent) 35%,
    transparent 50%
  );
  z-index: 1;
  pointer-events: none;
}
.neycher-hero__content {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: 2;
  padding: var(--hero-pt, 0px) 60px var(--hero-pb, 0px);
  max-width: 500px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}
.neycher-hero__heading {
  font-family: var(--n-font);
  font-size: var(--hero-heading-size, 48px);
  font-weight: 400;
  line-height: 1.15;
  color: var(--hero-heading-color, #fff);
  margin: 0 0 32px;
  letter-spacing: -0.5px;
}
.neycher-hero__btn {
  display: inline-block;
  background: var(--hero-btn-bg, #fff);
  color: var(--hero-btn-color, var(--n-color-heading));
  font-family: var(--n-font);
  font-size: 15px;
  font-weight: 500;
  text-decoration: none;
  padding: 16px 56px;
  border-radius: 4px;
  text-align: center;
  letter-spacing: 0.3px;
}
.neycher-hero__btn:hover {
  opacity: 0.9;
}

/* Tablet */
@media screen and (max-width: 999px) {
  .neycher-hero__media img {
    height: 480px;
  }
  .neycher-hero__heading {
    font-size: 36px;
  }
  .neycher-hero__content {
    padding-inline: 40px;
    max-width: 400px;
  }
}

/* Mobile */
@media screen and (max-width: 749px) {
  .neycher-hero {
    display: flex;
    flex-direction: column;
    padding-top: 70px;
  }
  .neycher-hero__media {
    position: relative;
  }
  .neycher-hero__media img {
    width: 100%;
    height: auto;
    object-position: center top;
    transform: none;
    margin-left: 0;
  }
  .neycher-hero__media::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 25%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      color-mix(in srgb, var(--hero-bg, #9AA7B6) 60%, transparent) 50%,
      var(--hero-bg, #9AA7B6) 100%
    );
    pointer-events: none;
  }
  .neycher-hero__overlay {
    display: none;
  }
  .neycher-hero__content {
    position: static;
    max-width: 100%;
    padding: 24px 24px 40px;
    background: transparent;
    align-items: center;
    text-align: center;
  }
  .neycher-hero__heading {
    font-size: 32px;
    margin-bottom: 24px;
  }
  .neycher-hero__btn {
    padding: 16px 0;
    font-size: 15px;
    width: 100%;
    border-radius: 4px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Hero",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Save up to 20%<br>with subscription"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background / overlay color",
      "default": "#9AA7B6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color",
      "default": "#1D2836"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 85,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 32,
      "max": 72,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Neycher Hero"
    }
  ]
}
{% endschema %}
