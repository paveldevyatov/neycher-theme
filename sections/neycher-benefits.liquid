{% stylesheet %}
.neycher-benefits {
  padding: 0;
  margin: 0;
}

/* Marquee */
.neycher-benefits__marquee {
  overflow: hidden;
  padding: 16px 0;
  background: #8EB3E7;
  color: #fff;
}
.neycher-benefits__marquee-track {
  display: flex;
  align-items: center;
  gap: 20px;
  white-space: nowrap;
  font-family: var(--n-font);
  font-size: 14px;
  font-weight: 400;
  color: #fff;
  animation: neycher-marquee 20s linear infinite;
  width: max-content;
}
@keyframes neycher-marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.neycher-benefits__dot {
  width: 4px;
  height: 4px;
  background: #fff;
  border-radius: 50%;
  flex-shrink: 0;
}

{% endstylesheet %}

