{% stylesheet %}
.neycher-benefits {
  padding: 60px 60px 40px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-benefits__visual {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 40px 0;
}
.neycher-benefits__node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.neycher-benefits__ellipse {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  object-fit: cover;
}
.neycher-benefits__label {
  font-family: "Open Sans", sans-serif;
  font-size: 14px;
  font-weight: 400;
  color: #000;
  text-align: center;
  line-height: 1.3;
  letter-spacing: -0.3px;
}
.neycher-benefits__line {
  width: 80px;
  height: auto;
  margin-bottom: 32px;
}
.neycher-benefits__marquee {
  overflow: hidden;
  padding: 20px 0;
  border-top: 1px solid #e5e5e5;
  border-bottom: 1px solid #e5e5e5;
  margin-top: 20px;
}
.neycher-benefits__marquee-track {
  display: flex;
  align-items: center;
  gap: 24px;
  white-space: nowrap;
  font-family: "Open Sans", sans-serif;
  font-size: 14px;
  font-weight: 400;
  color: #000;
}
.neycher-benefits__dot {
  width: 4px;
  height: 4px;
  background: #000;
  border-radius: 50%;
  flex-shrink: 0;
}
@media screen and (max-width: 749px) {
  .neycher-benefits {
    padding: 40px 16px 24px;
  }
  .neycher-benefits__visual {
    flex-wrap: wrap;
    gap: 16px;
  }
  .neycher-benefits__ellipse {
    width: 64px;
    height: 64px;
  }
  .neycher-benefits__line {
    width: 40px;
    margin-bottom: 24px;
  }
}
{% endstylesheet %}

