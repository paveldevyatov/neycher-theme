<section class="neycher-stats">
  <div class="neycher-stats__card">
    <div class="neycher-stats__left">
      <h2 class="neycher-stats__heading">Your tender parts deserve lab-verified results.</h2>
    </div>
    <div class="neycher-stats__right">
      <div class="neycher-stats__grid">
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">94<span class="neycher-stats__percent">%</span></div>
          <p class="neycher-stats__desc">Experienced noticeable improvement in vaginal dryness</p>
        </div>
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">96<span class="neycher-stats__percent">%</span></div>
          <p class="neycher-stats__desc">Reported positive impacts on emotional well-being</p>
        </div>
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">0<span class="neycher-stats__percent">%</span></div>
          <p class="neycher-stats__desc">Stopped feeling pain during sex</p>
        </div>
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">0<span class="neycher-stats__percent">%</span></div>
          <p class="neycher-stats__desc">Noticed improvements in sexual relationships</p>
        </div>
      </div>
      <p class="neycher-stats__footnote">*Based on a 4-week study of women aged 29-64 experiencing common vulvovaginal symptoms and general discomfort.</p>
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-stats {
  padding: 48px 60px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-stats__card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
  padding: 56px;
  background: #f7f5f2;
  border-radius: 16px;
}
.neycher-stats__heading {
  font-family: "Open Sans", sans-serif;
  font-size: 40px;
  font-weight: 300;
  line-height: 1.15;
  color: #000;
  margin: 0;
  letter-spacing: -0.5px;
}
.neycher-stats__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 36px;
}
.neycher-stats__number {
  font-family: "Open Sans", sans-serif;
  font-size: 56px;
  font-weight: 300;
  color: #000;
  line-height: 1;
  margin-bottom: 8px;
}
.neycher-stats__percent {
  font-size: 36px;
}
.neycher-stats__desc {
  font-family: "Open Sans", sans-serif;
  font-size: 14px;
  font-weight: 400;
  color: #555;
  margin: 0;
  line-height: 1.5;
}
.neycher-stats__footnote {
  font-family: "Open Sans", sans-serif;
  font-size: 11px;
  color: #999;
  margin: 28px 0 0;
  line-height: 1.4;
}
@media screen and (max-width: 999px) {
  .neycher-stats__card {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 36px;
  }
  .neycher-stats__heading {
    font-size: 32px;
  }
}
@media screen and (max-width: 749px) {
  .neycher-stats {
    padding: 32px 16px;
  }
  .neycher-stats__card {
    padding: 28px;
  }
  .neycher-stats__grid {
    gap: 24px;
  }
  .neycher-stats__number {
    font-size: 40px;
  }
  .neycher-stats__percent {
    font-size: 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Stats",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Stats"
    }
  ]
}
{% endschema %}
