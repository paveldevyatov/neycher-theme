<section class="neycher-stats">
  <div class="neycher-stats__inner">
    <div class="neycher-stats__left">
      <h2 class="neycher-stats__heading">Your tender parts deserve lab-verified results.</h2>
    </div>
    <div class="neycher-stats__right">
      <div class="neycher-stats__grid">
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">94%</div>
          <p class="neycher-stats__desc">Experienced noticeable improvement in vaginal dryness</p>
        </div>
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">96%</div>
          <p class="neycher-stats__desc">Reported positive impacts on emotional well-being</p>
        </div>
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">0%</div>
          <p class="neycher-stats__desc">Stopped feeling pain during sex</p>
        </div>
        <div class="neycher-stats__item">
          <div class="neycher-stats__number">0%</div>
          <p class="neycher-stats__desc">Noticed improvements in sexual relationships</p>
        </div>
      </div>
      <p class="neycher-stats__footnote">4-week clinical study, women aged 29-64</p>
    </div>
  </div>
  <div class="neycher-stats__cta">
    <div class="neycher-stats__cta-left">
      <p class="neycher-stats__cta-text">Feeling Good is a Science<br>We've Mastered</p>
      <a href="/collections/all" class="neycher-stats__cta-btn">Shop</a>
    </div>
    <div class="neycher-stats__cta-images">
      <img src="{{ 'product-vaginal-moisturizer.webp' | asset_url }}" alt="Vaginal Moisturizer" width="140" height="140">
      <img src="{{ 'product-synbiotic.webp' | asset_url }}" alt="Vaginal Synbiotic" width="140" height="140">
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-stats {
  padding: 60px 60px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-stats__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
  padding: 48px;
  background: #f7f5f2;
  border-radius: 12px;
}
.neycher-stats__heading {
  font-family: "Open Sans", sans-serif;
  font-size: 36px;
  font-weight: 300;
  line-height: 1.2;
  color: #000;
  margin: 0;
}
.neycher-stats__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
}
.neycher-stats__number {
  font-family: "Open Sans", sans-serif;
  font-size: 48px;
  font-weight: 300;
  color: #000;
  line-height: 1;
  margin-bottom: 8px;
}
.neycher-stats__desc {
  font-family: "Open Sans", sans-serif;
  font-size: 14px;
  font-weight: 400;
  color: #555;
  margin: 0;
  line-height: 1.4;
}
.neycher-stats__footnote {
  font-family: "Open Sans", sans-serif;
  font-size: 12px;
  color: #999;
  margin: 24px 0 0;
}
.neycher-stats__cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24px;
  padding: 40px 48px;
  background: #f0eee9;
  border-radius: 12px;
  overflow: hidden;
}
.neycher-stats__cta-left {
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.neycher-stats__cta-text {
  font-family: "Open Sans", sans-serif;
  font-size: 24px;
  font-weight: 300;
  color: #000;
  margin: 0;
  line-height: 1.3;
}
.neycher-stats__cta-btn {
  display: inline-block;
  background: #000;
  color: #fff;
  font-family: "Open Sans", sans-serif;
  font-size: 15px;
  font-weight: 400;
  text-decoration: none;
  padding: 14px 72px;
  border-radius: 0;
  letter-spacing: 0.5px;
  width: fit-content;
}
.neycher-stats__cta-btn:hover {
  opacity: 0.85;
}
.neycher-stats__cta-images {
  display: flex;
  gap: 12px;
  align-items: center;
}
.neycher-stats__cta-images img {
  width: 120px;
  height: 120px;
  object-fit: contain;
  border-radius: 8px;
}
@media screen and (max-width: 999px) {
  .neycher-stats__inner {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 32px;
  }
  .neycher-stats__heading {
    font-size: 28px;
  }
}
@media screen and (max-width: 749px) {
  .neycher-stats {
    padding: 40px 16px;
  }
  .neycher-stats__inner {
    padding: 24px;
  }
  .neycher-stats__grid {
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .neycher-stats__number {
    font-size: 36px;
  }
  .neycher-stats__cta {
    flex-direction: column;
    gap: 20px;
    padding: 24px;
    text-align: center;
  }
  .neycher-stats__cta-left {
    align-items: center;
  }
  .neycher-stats__cta-images img {
    width: 80px;
    height: 80px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Stats",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Stats"
    }
  ]
}
{% endschema %}
