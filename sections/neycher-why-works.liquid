{%- liquid
  assign bg_color = section.settings.bg_color
  assign heading_color = section.settings.heading_color
  assign text_color = section.settings.text_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

<section
  class="neycher-why n-section"
  style="
    background-color: {{ bg_color }};
    --nw-heading-color: {{ heading_color }};
    --nw-text-color: {{ text_color }};
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  "
>
  <div class="neycher-why__inner">
    <div class="neycher-why__left">
      <h2 class="neycher-why__title n-title-display">{{ section.settings.heading }}</h2>
      <p class="neycher-why__subtitle n-text">{{ section.settings.description }}</p>
      <ul class="neycher-why__features">
        <li class="neycher-why__feature">
          {%- if section.settings.feature_1_icon != blank -%}
            <img src="{{ section.settings.feature_1_icon | image_url: width: 72 }}" alt="" width="36" height="36">
          {%- else -%}
            <img src="{{ 'icon-natural.svg' | asset_url }}" alt="" width="36" height="36">
          {%- endif -%}
          <span>{{ section.settings.feature_1_text }}</span>
        </li>
        <li class="neycher-why__feature">
          {%- if section.settings.feature_2_icon != blank -%}
            <img src="{{ section.settings.feature_2_icon | image_url: width: 72 }}" alt="" width="36" height="36">
          {%- else -%}
            <img src="{{ 'icon-free.svg' | asset_url }}" alt="" width="36" height="36">
          {%- endif -%}
          <span>{{ section.settings.feature_2_text }}</span>
        </li>
        <li class="neycher-why__feature">
          {%- if section.settings.feature_3_icon != blank -%}
            <img src="{{ section.settings.feature_3_icon | image_url: width: 72 }}" alt="" width="36" height="36">
          {%- else -%}
            <img src="{{ 'icon-developed.svg' | asset_url }}" alt="" width="36" height="36">
          {%- endif -%}
          <span>{{ section.settings.feature_3_text }}</span>
        </li>
      </ul>
      <a href="{{ section.settings.button_link }}" class="neycher-why__link n-btn-square">{{ section.settings.button_text }}</a>
    </div>

    <div class="neycher-why__right">
      <div class="neycher-why__circle">
        {%- if section.settings.flower_image != blank -%}
          <img src="{{ section.settings.flower_image | image_url: width: 840 }}" alt="Chamomile flower" class="neycher-why__flower-img" width="500" height="500">
        {%- else -%}
          <img src="{{ 'why-works-flower.jpeg' | asset_url }}" alt="Chamomile flower" class="neycher-why__flower-img" width="500" height="500">
        {%- endif -%}

        <div class="neycher-why__badge neycher-why__badge--tl">
          {%- if section.settings.badge_1_image != blank -%}
            <img src="{{ section.settings.badge_1_image | image_url: width: 88 }}" alt="" width="44" height="44">
          {%- else -%}
            <img src="{{ 'benefit-ellipse-1.png' | asset_url }}" alt="" width="44" height="44">
          {%- endif -%}
          <span>{{ section.settings.badge_1_text }}</span>
          <div class="neycher-why__badge-line neycher-why__badge-line--tr"></div>
        </div>

        <div class="neycher-why__badge neycher-why__badge--tr">
          <span>{{ section.settings.badge_2_text }}</span>
          {%- if section.settings.badge_3_image != blank -%}
            <img src="{{ section.settings.badge_3_image | image_url: width: 88 }}" alt="" width="44" height="44">
          {%- else -%}
            <img src="{{ 'benefit-ellipse-3.png' | asset_url }}" alt="" width="44" height="44">
          {%- endif -%}
          <div class="neycher-why__badge-line neycher-why__badge-line--tl"></div>
        </div>

        <div class="neycher-why__badge neycher-why__badge--bl">
          {%- if section.settings.badge_2_image != blank -%}
            <img src="{{ section.settings.badge_2_image | image_url: width: 88 }}" alt="" width="44" height="44">
          {%- else -%}
            <img src="{{ 'benefit-ellipse-2.png' | asset_url }}" alt="" width="44" height="44">
          {%- endif -%}
          <span>{{ section.settings.badge_3_text }}</span>
          <div class="neycher-why__badge-line neycher-why__badge-line--tr"></div>
        </div>

        <div class="neycher-why__badge neycher-why__badge--br">
          <span>{{ section.settings.badge_4_text }}</span>
          {%- if section.settings.badge_4_image != blank -%}
            <img src="{{ section.settings.badge_4_image | image_url: width: 88 }}" alt="" width="44" height="44">
          {%- else -%}
            <img src="{{ 'benefit-ellipse-4.png' | asset_url }}" alt="" width="44" height="44">
          {%- endif -%}
          <div class="neycher-why__badge-line neycher-why__badge-line--tl"></div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-why {}
.neycher-why__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: center;
}
.neycher-why__left {
  max-width: 520px;
}
.neycher-why__title {
  margin: 0 0 24px;
  color: var(--nw-heading-color, var(--n-color-heading));
}
.neycher-why__subtitle {
  margin: 0 0 32px;
  line-height: 1.6;
  color: var(--nw-text-color, var(--n-color-text));
}
.neycher-why__features {
  list-style: none;
  padding: 0;
  margin: 0 0 36px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.neycher-why__feature {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--n-font);
  font-size: 15px;
  color: var(--nw-heading-color, var(--n-color-heading));
}
.neycher-why__feature img {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
}
.neycher-why__link {
  display: inline-block;
}

/* Right side — circle diagram */
.neycher-why__right {
  display: flex;
  justify-content: center;
  align-items: center;
}
.neycher-why__circle {
  position: relative;
  width: 500px;
  height: 500px;
}
.neycher-why__flower-img {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 420px;
  height: 420px;
  object-fit: cover;
  border-radius: 50%;
  z-index: 0;
}

/* Badge positioning */
.neycher-why__badge {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--n-font);
  font-size: 14px;
  color: var(--nw-heading-color, var(--n-color-heading));
  white-space: nowrap;
}
.neycher-why__badge img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
}
.neycher-why__badge-line {
  position: absolute;
  height: 1px;
  width: 60px;
  background: #1D2836;
}
.neycher-why__badge-line::before {
  content: '';
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #1D2836;
}
.neycher-why__badge-line--tr::before {
  left: 0;
}
.neycher-why__badge-line--tl::before {
  right: 0;
}

/* Top-left: Green Chemistry */
.neycher-why__badge--tl {
  top: 40px;
  left: 20px;
}
.neycher-why__badge--tl .neycher-why__badge-line {
  top: 50%;
  right: -70px;
}

/* Top-right: Extensive Research */
.neycher-why__badge--tr {
  top: 130px;
  right: -40px;
}
.neycher-why__badge--tr .neycher-why__badge-line {
  top: 50%;
  left: -70px;
}

/* Bottom-left: Microbiome Safety */
.neycher-why__badge--bl {
  bottom: 140px;
  left: -20px;
}
.neycher-why__badge--bl .neycher-why__badge-line {
  top: 50%;
  right: -70px;
}

/* Bottom-right: Patented Technology */
.neycher-why__badge--br {
  bottom: 40px;
  right: -40px;
}
.neycher-why__badge--br .neycher-why__badge-line {
  top: 50%;
  left: -70px;
}

@media screen and (max-width: 999px) {
  .neycher-why__inner {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .neycher-why__left {
    max-width: 100%;
  }
  .neycher-why__circle {
    width: 400px;
    height: 400px;
    margin: 0 auto;
  }
  .neycher-why__flower-img {
    width: 340px;
    height: 340px;
  }
}
@media screen and (max-width: 749px) {
  .neycher-why__title {
    font-size: 32px;
  }
  .neycher-why__subtitle {
    font-size: 15px;
  }
  .neycher-why__circle {
    width: 340px;
    height: 340px;
  }
  .neycher-why__flower-img {
    width: 260px;
    height: 260px;
  }
  .neycher-why__badge {
    font-size: 12px;
    gap: 6px;
  }
  .neycher-why__badge img {
    width: 32px;
    height: 32px;
  }
  .neycher-why__badge-line {
    width: 40px;
  }
  .neycher-why__badge--tl {
    top: 20px;
    left: 0;
  }
  .neycher-why__badge--tl .neycher-why__badge-line {
    right: -50px;
  }
  .neycher-why__badge--tr {
    top: 100px;
    right: -20px;
  }
  .neycher-why__badge--tr .neycher-why__badge-line {
    left: -50px;
  }
  .neycher-why__badge--bl {
    bottom: 100px;
    left: -10px;
  }
  .neycher-why__badge--bl .neycher-why__badge-line {
    right: -50px;
  }
  .neycher-why__badge--br {
    bottom: 30px;
    right: -20px;
  }
  .neycher-why__badge--br .neycher-why__badge-line {
    left: -50px;
  }
}
@media screen and (max-width: 400px) {
  .neycher-why__circle {
    width: 300px;
    height: 300px;
  }
  .neycher-why__flower-img {
    width: 220px;
    height: 220px;
  }
  .neycher-why__badge {
    font-size: 11px;
  }
  .neycher-why__badge img {
    width: 28px;
    height: 28px;
  }
  .neycher-why__badge--tl {
    top: 15px;
    left: 0;
  }
  .neycher-why__badge--tr {
    top: 85px;
    right: -15px;
  }
  .neycher-why__badge--bl {
    bottom: 85px;
    left: -5px;
  }
  .neycher-why__badge--br {
    bottom: 20px;
    right: -15px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Why Works",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why our products work"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Unlike the majority of vaginal suppositories that damage vaginal tissue and throw off the delicate balance of your microbiome, our products are carefully formulated to provide both immediate relief and long-term vulvovaginal restoration."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Discover Our Science"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "e.g. /pages/about"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "image_picker",
      "id": "feature_1_icon",
      "label": "Feature 1 icon"
    },
    {
      "type": "text",
      "id": "feature_1_text",
      "label": "Feature 1 text",
      "default": "All-natural bioavailable ingredients"
    },
    {
      "type": "image_picker",
      "id": "feature_2_icon",
      "label": "Feature 2 icon"
    },
    {
      "type": "text",
      "id": "feature_2_text",
      "label": "Feature 2 text",
      "default": "Free from bulking agents or fillers"
    },
    {
      "type": "image_picker",
      "id": "feature_3_icon",
      "label": "Feature 3 icon"
    },
    {
      "type": "text",
      "id": "feature_3_text",
      "label": "Feature 3 text",
      "default": "Developed from numerous clinical trials"
    },
    {
      "type": "header",
      "content": "Flower image"
    },
    {
      "type": "image_picker",
      "id": "flower_image",
      "label": "Flower image"
    },
    {
      "type": "header",
      "content": "Badge 1 (top-left)"
    },
    {
      "type": "image_picker",
      "id": "badge_1_image",
      "label": "Badge 1 image"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 text",
      "default": "Green Chemistry"
    },
    {
      "type": "header",
      "content": "Badge 2 (top-right)"
    },
    {
      "type": "image_picker",
      "id": "badge_2_image",
      "label": "Badge 2 image"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 text",
      "default": "Extensive Research"
    },
    {
      "type": "header",
      "content": "Badge 3 (bottom-left)"
    },
    {
      "type": "image_picker",
      "id": "badge_3_image",
      "label": "Badge 3 image"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3 text",
      "default": "Microbiome Safety"
    },
    {
      "type": "header",
      "content": "Badge 4 (bottom-right)"
    },
    {
      "type": "image_picker",
      "id": "badge_4_image",
      "label": "Badge 4 image"
    },
    {
      "type": "text",
      "id": "badge_4_text",
      "label": "Badge 4 text",
      "default": "Patented Technology"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1D2836"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Neycher Why Works"
    }
  ]
}
{% endschema %}
