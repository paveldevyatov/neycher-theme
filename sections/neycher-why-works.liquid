<section class="neycher-why n-section">
  <div class="neycher-why__inner">
    <div class="neycher-why__left">
      <h2 class="neycher-why__title n-title-display">Why our<br>products work</h2>
      <p class="neycher-why__subtitle n-text">Unlike the majority of vaginal suppositories that damage vaginal tissue and throw off the delicate balance of your microbiome, our products are carefully formulated to provide both immediate relief and long-term vulvovaginal restoration.</p>
      <ul class="neycher-why__features">
        <li class="neycher-why__feature">
          <img src="{{ 'icon-natural.svg' | asset_url }}" alt="" width="36" height="36">
          <span>All-natural bioavailable ingredients</span>
        </li>
        <li class="neycher-why__feature">
          <img src="{{ 'icon-free.svg' | asset_url }}" alt="" width="36" height="36">
          <span>Free from bulking agents or fillers</span>
        </li>
        <li class="neycher-why__feature">
          <img src="{{ 'icon-developed.svg' | asset_url }}" alt="" width="36" height="36">
          <span>Developed from numerous clinical trials</span>
        </li>
      </ul>
      <a href="/pages/about" class="neycher-why__link n-btn-square">Discover Our Science</a>
    </div>

    <div class="neycher-why__right">
      <div class="neycher-why__circle">
        <img src="{{ 'why-works-flower.jpeg' | asset_url }}" alt="Chamomile flower" class="neycher-why__flower-img" width="500" height="500">

        <div class="neycher-why__badge neycher-why__badge--tl">
          <img src="{{ 'benefit-ellipse-1.png' | asset_url }}" alt="" width="44" height="44">
          <span>Green Chemistry</span>
          <div class="neycher-why__badge-line neycher-why__badge-line--tr"></div>
        </div>

        <div class="neycher-why__badge neycher-why__badge--tr">
          <span>Extensive Research</span>
          <img src="{{ 'benefit-ellipse-3.png' | asset_url }}" alt="" width="44" height="44">
          <div class="neycher-why__badge-line neycher-why__badge-line--tl"></div>
        </div>

        <div class="neycher-why__badge neycher-why__badge--bl">
          <img src="{{ 'benefit-ellipse-2.png' | asset_url }}" alt="" width="44" height="44">
          <span>Microbiome Safety</span>
          <div class="neycher-why__badge-line neycher-why__badge-line--tr"></div>
        </div>

        <div class="neycher-why__badge neycher-why__badge--br">
          <span>Patented Technology</span>
          <img src="{{ 'benefit-ellipse-4.png' | asset_url }}" alt="" width="44" height="44">
          <div class="neycher-why__badge-line neycher-why__badge-line--tl"></div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-why {
  padding: 80px 60px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-why__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: center;
}
.neycher-why__left {
  max-width: 520px;
}
.neycher-why__title {
  margin: 0 0 24px;
}
.neycher-why__subtitle {
  margin: 0 0 32px;
  line-height: 1.6;
}
.neycher-why__features {
  list-style: none;
  padding: 0;
  margin: 0 0 36px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.neycher-why__feature {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--n-font);
  font-size: 15px;
  color: var(--n-color-heading);
}
.neycher-why__feature img {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
}
.neycher-why__link {
  display: inline-block;
}

/* Right side — circle diagram */
.neycher-why__right {
  display: flex;
  justify-content: center;
  align-items: center;
}
.neycher-why__circle {
  position: relative;
  width: 500px;
  height: 500px;
}
.neycher-why__flower-img {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 420px;
  height: 420px;
  object-fit: cover;
  border-radius: 50%;
  z-index: 0;
}

/* Badge positioning */
.neycher-why__badge {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--n-font);
  font-size: 14px;
  color: var(--n-color-heading);
  white-space: nowrap;
}
.neycher-why__badge img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
}
.neycher-why__badge-line {
  position: absolute;
  height: 1px;
  width: 60px;
  background: #1D2836;
}
.neycher-why__badge-line::before {
  content: '';
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #1D2836;
}
.neycher-why__badge-line--tr::before {
  left: 0;
}
.neycher-why__badge-line--tl::before {
  right: 0;
}

/* Top-left: Green Chemistry */
.neycher-why__badge--tl {
  top: 40px;
  left: 20px;
}
.neycher-why__badge--tl .neycher-why__badge-line {
  top: 50%;
  right: -70px;
}

/* Top-right: Extensive Research */
.neycher-why__badge--tr {
  top: 130px;
  right: -40px;
}
.neycher-why__badge--tr .neycher-why__badge-line {
  top: 50%;
  left: -70px;
}

/* Bottom-left: Microbiome Safety */
.neycher-why__badge--bl {
  bottom: 140px;
  left: -20px;
}
.neycher-why__badge--bl .neycher-why__badge-line {
  top: 50%;
  right: -70px;
}

/* Bottom-right: Patented Technology */
.neycher-why__badge--br {
  bottom: 40px;
  right: -40px;
}
.neycher-why__badge--br .neycher-why__badge-line {
  top: 50%;
  left: -70px;
}

@media screen and (max-width: 999px) {
  .neycher-why {
    padding: 60px 32px;
  }
  .neycher-why__inner {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .neycher-why__left {
    max-width: 100%;
    text-align: center;
  }
  .neycher-why__features {
    align-items: center;
  }
  .neycher-why__circle {
    width: 400px;
    height: 400px;
    margin: 0 auto;
  }
  .neycher-why__flower-img {
    width: 340px;
    height: 340px;
  }
}
@media screen and (max-width: 749px) {
  .neycher-why {
    padding: 48px 16px;
  }
  .neycher-why__title {
    font-size: 32px;
  }
  .neycher-why__subtitle {
    font-size: 14px;
  }
  .neycher-why__right {
    padding: 0 8px;
  }
  .neycher-why__circle {
    width: 280px;
    height: 280px;
  }
  .neycher-why__flower-img {
    width: 200px;
    height: 200px;
  }
  .neycher-why__badge {
    font-size: 11px;
    gap: 5px;
  }
  .neycher-why__badge img {
    width: 28px;
    height: 28px;
  }
  .neycher-why__badge-line {
    width: 30px;
  }
  /* Reposition badges closer on mobile */
  .neycher-why__badge--tl {
    top: 20px;
    left: 10px;
  }
  .neycher-why__badge--tl .neycher-why__badge-line {
    right: -36px;
  }
  .neycher-why__badge--tr {
    top: 80px;
    right: -10px;
  }
  .neycher-why__badge--tr .neycher-why__badge-line {
    left: -36px;
  }
  .neycher-why__badge--bl {
    bottom: 90px;
    left: 0;
  }
  .neycher-why__badge--bl .neycher-why__badge-line {
    right: -36px;
  }
  .neycher-why__badge--br {
    bottom: 20px;
    right: -10px;
  }
  .neycher-why__badge--br .neycher-why__badge-line {
    left: -36px;
  }
}
@media screen and (max-width: 479px) {
  .neycher-why__circle {
    width: 240px;
    height: 240px;
  }
  .neycher-why__flower-img {
    width: 170px;
    height: 170px;
  }
  .neycher-why__badge {
    font-size: 10px;
    gap: 4px;
  }
  .neycher-why__badge img {
    width: 24px;
    height: 24px;
  }
  .neycher-why__badge-line {
    display: none;
  }
  .neycher-why__badge--tl {
    top: 10px;
    left: 5px;
  }
  .neycher-why__badge--tr {
    top: 65px;
    right: -5px;
  }
  .neycher-why__badge--bl {
    bottom: 70px;
    left: -5px;
  }
  .neycher-why__badge--br {
    bottom: 10px;
    right: -5px;
  }
}
{% endstylesheet %}

