{%- assign product = section.settings.product -%}
{%- if product == blank -%}
  {%- assign product = all_products['vaginal-moisturizer'] -%}
{%- endif -%}
{%- if product != blank -%}
<section
  class="neycher-fp"
  style="
    --neycher-fp-bg: {{ section.settings.bg_color }};
    --neycher-fp-card-bg: {{ section.settings.card_bg }};
    --neycher-fp-heading-color: {{ section.settings.heading_color }};
    --neycher-fp-text-color: {{ section.settings.text_color }};
    --neycher-fp-badge-bg: {{ section.settings.badge_bg }};
    --neycher-fp-badge-color: {{ section.settings.badge_color }};
    --neycher-fp-min-height: {{ section.settings.min_height }}px;
    --neycher-fp-card-max-width: {{ section.settings.card_max_width }}px;
    --neycher-fp-card-radius: {{ section.settings.card_radius }}px;
    --neycher-fp-padding-top: {{ section.settings.padding_top }}px;
    --neycher-fp-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="neycher-fp__inner">
    <div class="neycher-fp__bg">
      {%- if section.settings.bg_image != blank -%}
        <img
          src="{{ section.settings.bg_image | image_url: width: 1600 }}"
          alt="{{ section.settings.bg_image.alt | default: product.title }}"
          loading="lazy"
          width="1600"
          height="900"
        >
      {%- elsif product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 1600 }}"
          alt="{{ product.featured_image.alt | default: product.title }}"
          loading="lazy"
          width="1600"
          height="900"
        >
      {%- endif -%}
    </div>
    <div class="neycher-fp__card">
      <div class="neycher-fp__glass-card">
        {%- if section.settings.badge != blank -%}
          <span class="neycher-fp__badge n-badge">{{ section.settings.badge }}</span>
        {%- endif -%}
        <div class="neycher-fp__img-wrap">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | default: product.title }}"
              loading="lazy"
              width="600"
              height="600"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'neycher-fp__placeholder' }}
          {%- endif -%}
        </div>
        <div class="neycher-fp__card-info">
          <div class="neycher-fp__card-top">
            <a href="{{ product.url }}" class="neycher-fp__name n-product-name">{{ product.title }}</a>
            <a href="{{ product.url }}" class="neycher-fp__cart-btn n-cart-btn n-cart-btn--muted" aria-label="View product">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
              </svg>
            </a>
          </div>
          <div class="neycher-fp__rating n-rating">
            <img src="{{ 'rating-stars.svg' | asset_url }}" alt="stars" width="80" height="16">
            <span>{{ product.metafields.custom.rating | default: '5.0' }} ({{ product.metafields.custom.reviews_count | default: '0' }})</span>
          </div>
          <p class="neycher-fp__desc n-product-desc">{{ section.settings.description | default: product.description | strip_html | truncate: 120 }}</p>
          <div class="neycher-fp__price n-product-price">Starting at {{ product.price | money }}</div>
        </div>
      </div>
    </div>
  </div>
  <div class="neycher-fp__mobile-bg">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 800 }}"
        alt="{{ section.settings.bg_image.alt | default: product.title }}"
        loading="lazy"
        width="800"
        height="600"
      >
    {%- elsif product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 800 }}"
        alt="{{ product.featured_image.alt | default: product.title }}"
        loading="lazy"
        width="800"
        height="600"
      >
    {%- endif -%}
  </div>
</section>
{%- endif -%}

{% stylesheet %}
.neycher-fp {
  padding: 0;
  margin: 0;
  background: var(--neycher-fp-bg, #D8DEE5);
  padding-top: var(--neycher-fp-padding-top, 0px);
  padding-bottom: var(--neycher-fp-padding-bottom, 0px);
}
.neycher-fp__inner {
  position: relative;
  overflow: hidden;
  display: flex;
}
.neycher-fp__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.neycher-fp__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.neycher-fp__card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 40px 40px 40px 60px;
  flex-shrink: 0;
}
.neycher-fp__badge {
  display: inline-block;
  font-family: var(--n-font);
  font-size: 12px;
  font-weight: 500;
  color: var(--neycher-fp-badge-color, #ffffff);
  background: var(--neycher-fp-badge-bg, #8b8fc7);
  border-radius: 100px;
  padding: 6px 16px;
  margin: 24px 0 0 28px;
  letter-spacing: 0.02em;
}
.neycher-fp__glass-card {
  background: var(--neycher-fp-card-bg, rgba(255, 255, 255, 0.75));
  backdrop-filter: blur(20px);
  border-radius: var(--neycher-fp-card-radius, 16px);
  width: 100%;
  max-width: var(--neycher-fp-card-max-width, 420px);
  overflow: hidden;
}
.neycher-fp__img-wrap {
  padding: 32px 32px 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.neycher-fp__img-wrap img {
  max-width: 100%;
  height: auto;
  object-fit: contain;
}
.neycher-fp__card-info {
  padding: 0 28px 28px;
}
.neycher-fp__card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 6px;
}
.neycher-fp__name {
  font-family: var(--n-font);
  font-size: 22px;
  font-weight: 500;
  color: var(--neycher-fp-heading-color, #1D2836);
  text-decoration: none;
  line-height: 1.3;
}
.neycher-fp__name:hover {
  text-decoration: underline;
}
.neycher-fp__cart-btn {
  width: 40px;
  height: 40px;
  background: rgba(232, 232, 232, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--neycher-fp-text-color, #555555);
  text-decoration: none;
  flex-shrink: 0;
}
.neycher-fp__cart-btn:hover {
  background: rgba(221, 221, 221, 0.8);
}
.neycher-fp__rating {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 8px;
  font-family: var(--n-font);
  font-size: 13px;
  color: var(--neycher-fp-text-color, #555555);
}
.neycher-fp__rating img {
  height: 14px;
  width: auto;
}
.neycher-fp__desc {
  font-family: var(--n-font);
  font-size: 14px;
  font-weight: 400;
  color: var(--neycher-fp-text-color, #555555);
  margin: 0 0 8px;
  line-height: 1.5;
}
.neycher-fp__price {
  font-family: var(--n-font);
  font-size: 16px;
  font-weight: 500;
  color: var(--neycher-fp-heading-color, #1D2836);
}
/* Mobile background image — hidden on desktop, shown below card on mobile */
.neycher-fp__mobile-bg {
  display: none;
}
@media screen and (max-width: 999px) {
  .neycher-fp__inner {
    flex-direction: column;
  }
  .neycher-fp__card {
    padding: 40px 32px;
    align-items: center;
  }
}
@media screen and (max-width: 749px) {
  .neycher-fp__bg {
    display: none;
  }
  .neycher-fp__card {
    padding: 32px 16px;
    min-height: auto;
    align-items: center;
  }
  .neycher-fp__glass-card {
    background: var(--neycher-fp-card-bg, rgba(255, 255, 255, 0.85));
    backdrop-filter: none;
    max-width: 100%;
  }
  .neycher-fp__img-wrap {
    padding: 20px 20px 16px;
  }
  .neycher-fp__card-info {
    padding: 0 20px 20px;
  }
  .neycher-fp__mobile-bg {
    display: block;
    width: 100%;
    max-height: 400px;
    overflow: hidden;
  }
  .neycher-fp__mobile-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Featured Product",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Full-width background image. Falls back to product image if empty."
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge text",
      "default": "Clinically studied"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Short description",
      "default": "Deep hydration for lasting vaginal moisture."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#D8DEE5"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "text",
      "id": "card_bg",
      "label": "Card background",
      "default": "rgba(255,255,255,0.75)",
      "info": "Supports rgba, e.g. rgba(255,255,255,0.75)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1D2836"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#8b8fc7"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Section min height",
      "min": 400,
      "max": 700,
      "step": 20,
      "default": 460,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "label": "Card max width",
      "min": 300,
      "max": 500,
      "step": 20,
      "default": 420,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Neycher Featured Product"
    }
  ]
}
{% endschema %}
