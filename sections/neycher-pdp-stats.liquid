{%- comment -%} Clinically tested stats — same layout as homepage {%- endcomment -%}
<section class="npdp-stats">
  <div class="npdp-stats__inner">
    <div class="npdp-stats__left">
      <h2 class="n-title-display npdp-stats__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="npdp-stats__text">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    <div class="npdp-stats__right">
      <div class="npdp-stats__grid">
        {%- for block in section.blocks -%}
          {%- assign pct = block.settings.value | remove: '%' | plus: 0 -%}
          {%- assign circumference = 94.2 -%}
          {%- assign filled = circumference | times: pct | divided_by: 100.0 -%}
          <div class="npdp-stats__item" {{ block.shopify_attributes }}>
            <div class="npdp-stats__number-row">
              <span class="npdp-stats__number">{{ block.settings.value }}</span>
              <svg class="npdp-stats__ring" width="36" height="36" viewBox="0 0 36 36">
                <circle cx="18" cy="18" r="15" fill="none" stroke="#e0e0e8" stroke-width="3"/>
                <circle cx="18" cy="18" r="15" fill="none" stroke="#8b8fc7" stroke-width="3" stroke-dasharray="{{ filled }} {{ circumference }}" stroke-dashoffset="23.6" stroke-linecap="round" transform="rotate(-90 18 18)"/>
              </svg>
            </div>
            <p class="npdp-stats__desc">{{ block.settings.description }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.npdp-stats {
  padding: 80px 60px;
  max-width: 1440px;
  margin: 0 auto;
}
.npdp-stats__inner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 80px;
  align-items: start;
}
.npdp-stats__heading {
  margin-bottom: 28px;
}
.npdp-stats__text {
  font-size: 15px;
  font-weight: 400;
  color: var(--n-color-body);
  line-height: 1.6;
  margin: 0;
  max-width: 480px;
}
.npdp-stats__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px 60px;
}
.npdp-stats__number-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}
.npdp-stats__number {
  font-size: 56px;
  font-weight: 400;
  color: var(--n-color-heading);
  line-height: 1;
}
.npdp-stats__ring {
  flex-shrink: 0;
}
.npdp-stats__desc {
  font-size: 14px;
  font-weight: 400;
  color: var(--n-color-body);
  margin: 0;
  line-height: 1.5;
}

@media screen and (max-width: 999px) {
  .npdp-stats {
    padding: 60px 24px;
  }
  .npdp-stats__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .npdp-stats__heading {
    font-size: 32px;
  }
}
@media screen and (max-width: 749px) {
  .npdp-stats {
    padding: 48px 16px;
  }
  .npdp-stats__grid {
    gap: 32px 24px;
  }
  .npdp-stats__number {
    font-size: 40px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "PDP Stats",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Clinically tested. Real people-approved." },
    { "type": "textarea", "id": "description", "label": "Description" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "96%" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "PDP Stats" }]
}
{% endschema %}
