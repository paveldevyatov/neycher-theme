<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} faq-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="faq-section__heading h3">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="faq-section__list">
      {%- for block in section.blocks -%}
        <details class="faq-section__item" {{ block.shopify_attributes }}>
          <summary class="faq-section__question">
            <span>{{ block.settings.question }}</span>
            <span class="faq-section__icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <div class="faq-section__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .faq-section__heading {
    margin: 0 0 32px;
  }

  .faq-section__list {
    max-width: 720px;
  }

  .faq-section__item {
    border-bottom: 1px solid rgb(var(--color-border-rgb) / 15%);
  }

  .faq-section__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    cursor: pointer;
    font-weight: 500;
    font-size: 1rem;
    list-style: none;
    min-height: 44px;
  }

  .faq-section__question::-webkit-details-marker {
    display: none;
  }

  .faq-section__icon {
    flex-shrink: 0;
    margin-left: 16px;
  }

  .faq-section__item[open] .faq-section__icon {
    transform: rotate(180deg);
  }

  .faq-section__answer {
    padding: 0 0 16px;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 48
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I use this product?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Apply a small amount to the affected area as needed. For best results, use consistently as part of your daily routine.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "category": "t:categories.product",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How do I use this product?", "answer": "<p>Apply a small amount to the affected area as needed. For best results, use consistently as part of your daily routine.</p>" } },
        { "type": "faq_item", "settings": { "question": "Is this safe for sensitive skin?", "answer": "<p>Yes, all our products are dermatologist and gynecologist tested, pH-balanced, and free from parabens, sulfates, and artificial fragrances.</p>" } },
        { "type": "faq_item", "settings": { "question": "How long until I see results?", "answer": "<p>Most users report noticeable improvement within 7 days of consistent use. Results may vary depending on individual conditions.</p>" } }
      ]
    }
  ]
}
{% endschema %}
