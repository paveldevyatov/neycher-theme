{%- comment -%} Science-backed ingredients grid {%- endcomment -%}
<section class="npdp-ing">
  <div class="npdp-ing__inner">
    <h2 class="npdp-ing__heading">{{ section.settings.heading }}</h2>
    <div class="npdp-ing__grid">
      {%- for block in section.blocks -%}
        <div class="npdp-ing__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="npdp-ing__icon">
              <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.title | escape }}" width="100" height="100" loading="lazy">
            </div>
          {%- endif -%}
          <h3 class="npdp-ing__name">{{ block.settings.title }}</h3>
          <p class="npdp-ing__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.npdp-ing {
  max-width: 1440px;
  margin: 0 auto;
  padding: 80px 60px;
}
.npdp-ing__heading {
  font-size: 42px;
  font-weight: 400;
  color: var(--n-color-heading);
  margin: 0 0 48px;
  line-height: 1.1;
  max-width: 420px;
}
.npdp-ing__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}
.npdp-ing__icon {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 20px;
}
.npdp-ing__icon img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.npdp-ing__name {
  font-size: 16px;
  font-weight: 500;
  color: var(--n-color-heading);
  margin: 0 0 8px;
}
.npdp-ing__desc {
  font-size: 14px;
  font-weight: 400;
  color: var(--n-color-muted);
  line-height: 1.5;
  margin: 0;
}
@media screen and (max-width: 999px) {
  .npdp-ing {
    padding: 60px 24px;
  }
  .npdp-ing__heading {
    font-size: 32px;
    margin-bottom: 36px;
  }
  .npdp-ing__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 24px;
  }
}
@media screen and (max-width: 749px) {
  .npdp-ing {
    padding: 48px 16px;
  }
  .npdp-ing__heading {
    font-size: 28px;
  }
  .npdp-ing__grid {
    gap: 28px 16px;
  }
  .npdp-ing__icon {
    width: 80px;
    height: 80px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "PDP Ingredients",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Science-backed ingredients"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon image" },
        { "type": "text", "id": "title", "label": "Name", "default": "Ingredient" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "PDP Ingredients" }]
}
{% endschema %}
