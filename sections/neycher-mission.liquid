<section class="neycher-mission">
  <div class="neycher-mission__inner">
    <div class="neycher-mission__textblock">
      <span class="neycher-mission__line">
        <span>Deeply Attuned</span>
        <span class="neycher-mission__note neycher-mission__note--right">We stand for clean, conscious,<br>high-performance care.</span>
      </span>
      <span class="neycher-mission__line">
        <span>To</span>
        <img src="{{ 'ellipse-1.webp' | asset_url }}" alt="" class="neycher-mission__ellipse" width="70" height="70">
        <span>the <em>Evolving</em> Needs</span>
      </span>
      <span class="neycher-mission__line">
        <span>Of <em>Vagina</em> And <em>Vulva</em> At</span>
        <img src="{{ 'ellipse-2.webp' | asset_url }}" alt="" class="neycher-mission__ellipse" width="70" height="70">
        <span>Every</span>
      </span>
      <span class="neycher-mission__line">
        <span class="neycher-mission__note neycher-mission__note--left">We believe that intimate care should be as<br>powerful as any other form of self-care</span>
        <img src="{{ 'ellipse-3.webp' | asset_url }}" alt="" class="neycher-mission__ellipse" width="70" height="70">
        <span>Stage Of Life</span>
      </span>
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-mission {
  padding: 6.9vw 4.2vw;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-mission__inner {
  max-width: 1200px;
  margin: 0 auto;
}
.neycher-mission__textblock {
  font-family: var(--n-font);
  font-size: 5.55vw;
  font-weight: 300;
  line-height: 1.05;
  color: var(--n-color-heading);
  letter-spacing: -0.1vw;
  text-align: center;
}
.neycher-mission__textblock em {
  font-style: italic;
}
.neycher-mission__line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.25vw;
  flex-wrap: nowrap;
  position: relative;
}
.neycher-mission__ellipse {
  width: 4.86vw;
  height: 4.86vw;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}

/* Small annotation text */
.neycher-mission__note {
  font-family: var(--n-font);
  font-size: clamp(9px, 1.25vw, 18px);
  font-weight: 400;
  color: var(--n-color-body);
  line-height: 1.5;
  letter-spacing: 0;
  white-space: nowrap;
  flex-shrink: 0;
}
.neycher-mission__note--right {
  text-align: left;
  margin-left: 1.1vw;
}
.neycher-mission__note--left {
  text-align: left;
  margin-right: 1.1vw;
}

/* Cap max sizes on large screens */
@media screen and (min-width: 1441px) {
  .neycher-mission {
    padding: 100px 60px;
  }
  .neycher-mission__textblock {
    font-size: 80px;
    letter-spacing: -1.5px;
  }
  .neycher-mission__line {
    gap: 18px;
  }
  .neycher-mission__ellipse {
    width: 70px;
    height: 70px;
  }
  .neycher-mission__note {
    font-size: 14px;
  }
  .neycher-mission__note--right {
    margin-left: 16px;
  }
  .neycher-mission__note--left {
    margin-right: 16px;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Mission",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Mission"
    }
  ]
}
{% endschema %}
