<section class="neycher-categories">
  <div class="neycher-categories__grid">
    <a href="/collections/women-45" class="neycher-categories__card">
      <img src="{{ 'category-women45.webp' | asset_url }}" alt="Woman 45+" loading="lazy" width="400" height="560">
      <span class="neycher-categories__label">Woman 45+</span>
    </a>
    <a href="/collections/bv-and-yeast" class="neycher-categories__card">
      <img src="{{ 'category-bv.webp' | asset_url }}" alt="BV And Yeast" loading="lazy" width="400" height="560">
      <span class="neycher-categories__label">BV And Yeast</span>
    </a>
    <a href="/collections/postpartum" class="neycher-categories__card">
      <img src="{{ 'category-postpartum.webp' | asset_url }}" alt="Postpartum" loading="lazy" width="400" height="560">
      <span class="neycher-categories__label">Postpartum</span>
    </a>
    <a href="/collections/bundle-and-save" class="neycher-categories__card">
      <img src="{{ 'category-bundle.webp' | asset_url }}" alt="Bundle and Save" loading="lazy" width="400" height="560">
      <span class="neycher-categories__label">Bundle and Save</span>
    </a>
  </div>
</section>

{% stylesheet %}
.neycher-categories {
  padding: 60px 60px 40px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-categories__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.neycher-categories__card {
  position: relative;
  display: block;
  text-decoration: none;
  border-radius: 16px;
  overflow: hidden;
  aspect-ratio: 3 / 4;
}
.neycher-categories__card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.neycher-categories__label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  font-family: var(--n-font);
  font-size: 22px;
  font-weight: 400;
  font-style: italic;
  color: #fff;
  text-align: center;
  background: rgba(255, 255, 255, 0.15);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  backdrop-filter: blur(20px) saturate(180%);
  border-radius: 0 0 16px 16px;
}
@media screen and (max-width: 749px) {
  .neycher-categories {
    padding: 40px 16px 24px;
  }
  .neycher-categories__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .neycher-categories__label {
    font-size: 14px;
    padding: 12px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Categories",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Categories"
    }
  ]
}
{% endschema %}
