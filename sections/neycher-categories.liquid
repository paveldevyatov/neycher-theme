<section class="neycher-categories" style="--cat-pt: {{ section.settings.padding_top }}px; --cat-pb: {{ section.settings.padding_bottom }}px; --cat-gap: {{ section.settings.gap }}px; --cat-radius: {{ section.settings.border_radius }}px; --cat-label-size: {{ section.settings.label_size }}px; --cat-label-color: {{ section.settings.label_color }}; --cat-bg: {{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="neycher-categories__title">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="neycher-categories__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="neycher-categories__card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="400" height="560">
        {%- elsif block.settings.image_asset != blank -%}
          <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="400" height="560">
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'neycher-categories__placeholder' }}
        {%- endif -%}
        <span class="neycher-categories__label">{{ block.settings.label }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
.neycher-categories {
  padding: var(--cat-pt, 60px) 60px var(--cat-pb, 40px);
  max-width: 1440px;
  margin: 0 auto;
  background: var(--cat-bg, transparent);
}
.neycher-categories__title {
  display: none;
  font-family: var(--n-font);
  font-size: 24px;
  font-weight: 400;
  color: var(--n-color-heading);
  margin: 0 0 20px;
}
.neycher-categories__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--cat-gap, 20px);
}
.neycher-categories__card {
  position: relative;
  display: block;
  text-decoration: none;
  border-radius: var(--cat-radius, 16px);
  overflow: hidden;
  aspect-ratio: 3 / 4;
}
.neycher-categories__card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.neycher-categories__label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  font-family: var(--n-font);
  font-size: var(--cat-label-size, 22px);
  font-weight: 400;
  color: var(--cat-label-color, #fff);
  text-align: center;
  background: rgba(255, 255, 255, 0.15);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  backdrop-filter: blur(20px) saturate(180%);
  border-radius: 0 0 var(--cat-radius, 16px) var(--cat-radius, 16px);
}
@media screen and (max-width: 749px) {
  .neycher-categories {
    padding: 32px 16px 24px;
  }
  .neycher-categories__title {
    display: block;
  }
  .neycher-categories__grid {
    grid-template-columns: none;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 12px;
  }
  .neycher-categories__grid::-webkit-scrollbar {
    display: none;
  }
  .neycher-categories__card {
    flex: 0 0 42%;
    scroll-snap-align: start;
    aspect-ratio: 3 / 4;
  }
  .neycher-categories__label {
    font-size: 14px;
    padding: 12px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Categories",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (mobile only)",
      "default": "Shop by category"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 40,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 14,
      "max": 32,
      "step": 1,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Image asset filename",
          "info": "Overrides image picker. Use for theme asset files."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neycher Categories",
      "blocks": [
        { "type": "category", "settings": { "label": "Woman 45+", "image_asset": "category-women45.webp" } },
        { "type": "category", "settings": { "label": "BV And Yeast", "image_asset": "category-bv.webp" } },
        { "type": "category", "settings": { "label": "Postpartum", "image_asset": "category-postpartum.webp" } },
        { "type": "category", "settings": { "label": "Bundle and Save", "image_asset": "category-bundle.webp" } }
      ]
    }
  ]
}
{% endschema %}
