<section class="neycher-categories">
  <div class="neycher-categories__grid">
    <a href="/collections/women-45" class="neycher-categories__card">
      <div class="neycher-categories__img">
        <img src="{{ 'category-women45.webp' | asset_url }}" alt="Woman 45+" loading="lazy" width="400" height="300">
      </div>
      <span class="neycher-categories__label">Woman 45+</span>
    </a>
    <a href="/collections/bv-and-yeast" class="neycher-categories__card">
      <div class="neycher-categories__img">
        <img src="{{ 'category-bv.webp' | asset_url }}" alt="BV And Yeast" loading="lazy" width="400" height="300">
      </div>
      <span class="neycher-categories__label">BV And Yeast</span>
    </a>
    <a href="/collections/postpartum" class="neycher-categories__card">
      <div class="neycher-categories__img">
        <img src="{{ 'category-postpartum.webp' | asset_url }}" alt="Postpartum" loading="lazy" width="400" height="300">
      </div>
      <span class="neycher-categories__label">Postpartum</span>
    </a>
    <a href="/collections/bundle-and-save" class="neycher-categories__card">
      <div class="neycher-categories__img">
        <img src="{{ 'category-bundle.webp' | asset_url }}" alt="Bundle and Save" loading="lazy" width="400" height="300">
      </div>
      <span class="neycher-categories__label">Bundle and Save</span>
    </a>
  </div>
</section>

{% stylesheet %}
.neycher-categories {
  padding: 60px 60px 40px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-categories__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.neycher-categories__card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  gap: 16px;
}
.neycher-categories__img {
  aspect-ratio: 4 / 3;
  overflow: hidden;
  border-radius: 16px;
  width: 100%;
}
.neycher-categories__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.neycher-categories__label {
  font-family: "Open Sans", sans-serif;
  font-size: 20px;
  font-weight: 300;
  font-style: italic;
  color: #000;
  text-align: center;
}
@media screen and (max-width: 749px) {
  .neycher-categories {
    padding: 40px 16px 24px;
  }
  .neycher-categories__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .neycher-categories__label {
    font-size: 16px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Categories",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Categories"
    }
  ]
}
{% endschema %}
