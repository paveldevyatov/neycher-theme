<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} testimonials-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="testimonials-section__heading h3">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="testimonials-section__grid">
      {%- for block in section.blocks -%}
        <div class="testimonials-section__card" {{ block.shopify_attributes }}>
          {%- if block.settings.rating > 0 -%}
            <div class="testimonials-section__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}
                  <span class="testimonials-section__star testimonials-section__star--filled">&#9733;</span>
                {%- else -%}
                  <span class="testimonials-section__star">&#9733;</span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if block.settings.quote != blank -%}
            <blockquote class="testimonials-section__quote">{{ block.settings.quote }}</blockquote>
          {%- endif -%}

          <div class="testimonials-section__author-row">
            {%- if block.settings.image != blank -%}
              <div class="testimonials-section__avatar">
                {{ block.settings.image | image_url: width: 80 | image_tag: width: 40, height: 40, alt: block.settings.author, class: 'testimonials-section__avatar-img' }}
              </div>
            {%- endif -%}
            {%- if block.settings.author != blank -%}
              <cite class="testimonials-section__author">{{ block.settings.author }}</cite>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .testimonials-section__heading {
    margin: 0 0 32px;
  }

  .testimonials-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media screen and (min-width: 750px) {
    .testimonials-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .testimonials-section__card {
    padding: 24px;
    border: 1px solid rgb(var(--color-border-rgb) / 20%);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .testimonials-section__stars {
    display: flex;
    gap: 2px;
    font-size: 1rem;
  }

  .testimonials-section__star {
    color: rgb(var(--color-border-rgb) / 30%);
  }

  .testimonials-section__star--filled {
    color: #E5A100;
  }

  .testimonials-section__quote {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    font-style: normal;
  }

  .testimonials-section__author-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
  }

  .testimonials-section__avatar-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonials-section__author {
    font-style: normal;
    font-size: 0.875rem;
    font-weight: 600;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "In your words"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This product completely changed my daily routine. I feel so much more confident and comfortable."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Author photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Finally a brand that understands intimate health. The products are gentle yet effective.",
            "author": "Sarah M."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "I've tried everything and nothing worked until Neycher. The difference was noticeable within days.",
            "author": "Jessica L."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Clean ingredients, beautiful packaging, and it actually works. What more could you ask for?",
            "author": "Amanda R."
          }
        }
      ]
    }
  ]
}
{% endschema %}
