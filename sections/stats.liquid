<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} stats-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="stats-section__content">
    {%- if section.settings.heading != blank -%}
      <div class="stats-section__header">
        <h2 class="stats-section__heading h3">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="stats-section__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="stats-section__grid" style="--stats-columns: {{ section.blocks.size }};">
        {%- for block in section.blocks -%}
          <div class="stats-section__item" {{ block.shopify_attributes }}>
            <span class="stats-section__number h2">{{ block.settings.number }}</span>
            <p class="stats-section__description">{{ block.settings.description }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .stats-section__content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .stats-section__header {
    max-width: 480px;
  }

  .stats-section__heading {
    margin: 0;
  }

  .stats-section__subheading {
    margin: 8px 0 0;
  }

  .stats-section__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  @media screen and (min-width: 750px) {
    .stats-section__content {
      flex-direction: row;
      align-items: flex-start;
      gap: 48px;
    }

    .stats-section__header {
      flex: 0 0 240px;
    }

    .stats-section__grid {
      flex: 1;
    }
  }

  @media screen and (min-width: 990px) {
    .stats-section__content {
      gap: 60px;
    }

    .stats-section__header {
      flex: 0 0 280px;
    }

    .stats-section__grid {
      grid-template-columns: repeat(var(--stats-columns, 4), 1fr);
    }
  }

  .stats-section__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stats-section__number {
    margin: 0;
    line-height: 1;
  }

  .stats-section__description {
    margin: 0;
    font-size: 0.875rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Stats",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your tender parts deserve lab-verified results"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "stat_item",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "94%"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "of users reported improvement"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats",
      "category": "t:categories.storytelling",
      "blocks": [
        { "type": "stat_item", "settings": { "number": "94%", "description": "reported symptom relief within 7 days" } },
        { "type": "stat_item", "settings": { "number": "96%", "description": "would recommend to a friend" } },
        { "type": "stat_item", "settings": { "number": "84%", "description": "noticed improvement after first use" } },
        { "type": "stat_item", "settings": { "number": "88%", "description": "said it exceeded expectations" } }
      ]
    }
  ]
}
{% endschema %}
