{%- comment -%} Customer reviews carousel {%- endcomment -%}
<section class="neycher-reviews n-section">
  <div class="n-section-header">
    <h2 class="n-title-section">{{ section.settings.heading }}</h2>
    <div class="neycher-reviews__controls">
      <button class="neycher-reviews__arrow" data-reviews-prev aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 14l-5-5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="neycher-reviews__arrow" data-reviews-next aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
  <div class="neycher-reviews__scroll n-scroll-container" data-reviews-scroll>
    <div class="neycher-reviews__grid">
      {%- for block in section.blocks -%}
        <div class="neycher-reviews__card" {{ block.shopify_attributes }}>
          <div class="neycher-reviews__rating">5 ★★★★★</div>
          <blockquote class="neycher-reviews__quote">"{{ block.settings.quote }}"</blockquote>
          <div class="neycher-reviews__author">
            {%- if block.settings.avatar_asset != blank -%}
              <img src="{{ block.settings.avatar_asset | asset_url }}" alt="{{ block.settings.name }}" class="neycher-reviews__avatar" width="48" height="48">
            {%- elsif block.settings.avatar != blank -%}
              <img src="{{ block.settings.avatar | image_url: width: 96 }}" alt="{{ block.settings.name }}" class="neycher-reviews__avatar" width="48" height="48">
            {%- endif -%}
            <span class="neycher-reviews__name">{{ block.settings.name }}, {{ block.settings.location }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
  <div class="n-scroll-progress"><div class="n-scroll-progress__bar"></div></div>
</section>

<script>
  (function() {
    var scrollEl = document.querySelector('[data-reviews-scroll]');
    if (!scrollEl) return;
    var section = scrollEl.closest('.neycher-reviews');
    var prevBtn = section.querySelector('[data-reviews-prev]');
    var nextBtn = section.querySelector('[data-reviews-next]');
    var grid = scrollEl.querySelector('.neycher-reviews__grid');

    function getStep() {
      var card = grid.querySelector('.neycher-reviews__card');
      if (!card) return 320;
      var gap = parseInt(getComputedStyle(grid).columnGap) || 16;
      return card.offsetWidth + gap;
    }

    nextBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: getStep(), behavior: 'smooth' });
    });
    prevBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });
  })();
</script>

{% stylesheet %}
/* Header */
.neycher-reviews .n-section-header {
  margin-bottom: 24px;
}
.neycher-reviews__controls {
  display: flex;
  align-items: center;
  gap: 12px;
}
.neycher-reviews__arrow {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--n-color-border);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--n-color-heading);
}
.neycher-reviews__arrow:hover {
  border-color: var(--n-color-heading);
}

/* Scroll */
.neycher-reviews__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  scroll-snap-type: x mandatory;
}
.neycher-reviews__scroll::-webkit-scrollbar {
  display: none;
}

/* Grid */
.neycher-reviews__grid {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc(33.333% - 11px);
  gap: 16px;
}

/* Card */
.neycher-reviews__card {
  background: #fff;
  border: 1px solid var(--n-color-border);
  border-radius: 16px;
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  min-height: 220px;
  scroll-snap-align: start;
}
.neycher-reviews__rating {
  font-size: 14px;
  font-weight: 500;
  color: var(--n-color-heading);
  letter-spacing: 0.02em;
}
.neycher-reviews__quote {
  font-size: 15px;
  font-weight: 400;
  color: var(--n-color-heading);
  margin: 0;
  line-height: 1.55;
  font-style: normal;
  flex-grow: 1;
}
.neycher-reviews__author {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
  padding-top: 8px;
}
.neycher-reviews__avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}
.neycher-reviews__name {
  font-size: 14px;
  font-weight: 400;
  color: var(--n-color-body);
}

@media screen and (max-width: 999px) {
  .neycher-reviews__grid {
    grid-auto-columns: calc(50% - 8px);
  }
}
@media screen and (max-width: 749px) {
  .neycher-reviews__grid {
    grid-auto-columns: 280px;
    gap: 12px;
  }
}
{% endstylesheet %}

