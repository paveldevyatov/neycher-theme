{% stylesheet %}
.neycher-reviews {
  padding: 60px 60px 48px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-reviews__title {
  font-family: "Open Sans", sans-serif;
  font-size: 18px;
  font-weight: 400;
  color: #000;
  margin: 0 0 24px;
}
.neycher-reviews__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.neycher-reviews__scroll::-webkit-scrollbar {
  display: none;
}
.neycher-reviews__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.neycher-reviews__card {
  background: #f7f5f2;
  border-radius: 12px;
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  min-height: 220px;
}
.neycher-reviews__stars {
  width: 88px;
  height: auto;
}
.neycher-reviews__quote {
  font-family: "Open Sans", sans-serif;
  font-size: 14px;
  font-weight: 400;
  color: #000;
  margin: 0;
  line-height: 1.6;
  font-style: normal;
  flex-grow: 1;
}
.neycher-reviews__author {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
  padding-top: 8px;
}
.neycher-reviews__avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  object-fit: cover;
}
.neycher-reviews__name {
  font-family: "Open Sans", sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: #000;
}
.neycher-reviews__location {
  font-family: "Open Sans", sans-serif;
  font-size: 12px;
  color: #777;
}
@media screen and (max-width: 999px) {
  .neycher-reviews__grid {
    grid-template-columns: repeat(3, 320px);
  }
}
@media screen and (max-width: 749px) {
  .neycher-reviews {
    padding: 40px 16px 32px;
  }
  .neycher-reviews__grid {
    grid-template-columns: repeat(3, 280px);
    gap: 12px;
  }
}
{% endstylesheet %}

