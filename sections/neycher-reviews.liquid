{%- comment -%} Customer reviews carousel {%- endcomment -%}

{%- liquid
  assign cards_per_row = section.settings.cards_per_row | default: 3
  assign gap_px = 16
  assign gap_total = gap_px | times: cards_per_row | minus: gap_px
-%}

<section
  class="neycher-reviews n-section"
  style="
    --nr-bg: {{ section.settings.bg_color }};
    --nr-card-bg: {{ section.settings.card_bg }};
    --nr-card-border: {{ section.settings.card_border }};
    --nr-heading-color: {{ section.settings.heading_color }};
    --nr-text-color: {{ section.settings.text_color }};
    --nr-author-color: {{ section.settings.author_color }};
    --nr-card-radius: {{ section.settings.card_radius }}px;
    --nr-cards-per-row: {{ cards_per_row }};
    --nr-gap: {{ gap_px }}px;
    --nr-gap-total: {{ gap_total }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: var(--nr-bg);
  "
>
  <div class="n-section-header">
    <h2 class="n-title-section" style="color: var(--nr-heading-color);">{{ section.settings.heading }}</h2>
  </div>
  <div class="neycher-reviews__slider">
    <button class="neycher-reviews__arrow neycher-reviews__arrow--prev" data-reviews-prev aria-label="Previous">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 14l-5-5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="neycher-reviews__arrow neycher-reviews__arrow--next" data-reviews-next aria-label="Next">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="neycher-reviews__scroll n-scroll-container" data-reviews-scroll>
    <div class="neycher-reviews__grid">
      {%- for block in section.blocks -%}
        <div class="neycher-reviews__card" {{ block.shopify_attributes }}>
          <div class="neycher-reviews__rating">5 ★★★★★</div>
          <blockquote class="neycher-reviews__quote">"{{ block.settings.quote }}"</blockquote>
          <div class="neycher-reviews__author">
            {%- if block.settings.avatar_asset != blank -%}
              <img src="{{ block.settings.avatar_asset | asset_url }}" alt="{{ block.settings.name }}" class="neycher-reviews__avatar" width="48" height="48">
            {%- elsif block.settings.avatar != blank -%}
              <img src="{{ block.settings.avatar | image_url: width: 96 }}" alt="{{ block.settings.name }}" class="neycher-reviews__avatar" width="48" height="48">
            {%- endif -%}
            <span class="neycher-reviews__name">{{ block.settings.name }}, {{ block.settings.location }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
    </div>
  </div>
  <div class="n-scroll-progress"><div class="n-scroll-progress__bar"></div></div>
</section>

<script>
  (function() {
    var scrollEl = document.querySelector('[data-reviews-scroll]');
    if (!scrollEl) return;
    var section = scrollEl.closest('.neycher-reviews');
    var prevBtn = section.querySelector('[data-reviews-prev]');
    var nextBtn = section.querySelector('[data-reviews-next]');
    var grid = scrollEl.querySelector('.neycher-reviews__grid');

    function getStep() {
      var card = grid.querySelector('.neycher-reviews__card');
      if (!card) return 320;
      var gap = parseInt(getComputedStyle(grid).columnGap) || 16;
      return card.offsetWidth + gap;
    }

    nextBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: getStep(), behavior: 'smooth' });
    });
    prevBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });

    var progressBar = section.querySelector('.n-scroll-progress__bar');
    function updateProgress() {
      if (!progressBar) return;
      var maxScroll = scrollEl.scrollWidth - scrollEl.clientWidth;
      if (maxScroll <= 0) {
        progressBar.style.width = '100%';
        return;
      }
      var ratio = scrollEl.clientWidth / scrollEl.scrollWidth;
      var pos = scrollEl.scrollLeft / maxScroll;
      var barW = Math.max(ratio * 100, 10);
      var maxLeft = 100 - barW;
      progressBar.style.width = barW + '%';
      progressBar.style.transform = 'translateX(' + (pos * maxLeft / barW * 100) + '%)';
    }
    scrollEl.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  })();
</script>

{% stylesheet %}
/* Header */
.neycher-reviews .n-section-header {
  margin-bottom: 24px;
}
/* Slider wrapper */
.neycher-reviews__slider {
  position: relative;
}
.neycher-reviews__arrow {
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  z-index: 2;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--nr-card-border, var(--n-color-border));
  background: var(--nr-card-bg, #fff);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--nr-heading-color, var(--n-color-heading));
}
.neycher-reviews__arrow--prev {
  left: -20px;
}
.neycher-reviews__arrow--next {
  right: -20px;
}
.neycher-reviews__arrow:hover {
  border-color: var(--nr-heading-color, var(--n-color-heading));
}

/* Scroll */
.neycher-reviews__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  scroll-snap-type: x mandatory;
}
.neycher-reviews__scroll::-webkit-scrollbar {
  display: none;
}

/* Grid — desktop uses cards_per_row via CSS custom property */
.neycher-reviews__grid {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc((100% - var(--nr-gap-total, 32px)) / var(--nr-cards-per-row, 3));
  gap: var(--nr-gap, 16px);
}

/* Card */
.neycher-reviews__card {
  background: var(--nr-card-bg, #fff);
  border: 1px solid var(--nr-card-border, var(--n-color-border));
  border-radius: var(--nr-card-radius, 16px);
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  min-height: 220px;
  scroll-snap-align: start;
}
.neycher-reviews__rating {
  font-size: 14px;
  font-weight: 500;
  color: var(--nr-heading-color, var(--n-color-heading));
  letter-spacing: 0.02em;
}
.neycher-reviews__quote {
  font-size: 15px;
  font-weight: 400;
  color: var(--nr-text-color, var(--n-color-heading));
  margin: 0;
  line-height: 1.55;
  font-style: normal;
  flex-grow: 1;
}
.neycher-reviews__author {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
  padding-top: 8px;
}
.neycher-reviews__avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}
.neycher-reviews__name {
  font-size: 14px;
  font-weight: 400;
  color: var(--nr-author-color, var(--n-color-body));
}

@media screen and (max-width: 999px) {
  .neycher-reviews__grid {
    grid-auto-columns: calc(50% - 8px);
  }
}
@media screen and (max-width: 749px) {
  .neycher-reviews__grid {
    grid-auto-columns: 280px;
    gap: 12px;
  }
  .neycher-reviews__arrow {
    width: 32px;
    height: 32px;
  }
  .neycher-reviews__arrow svg {
    width: 14px;
    height: 14px;
  }
  .neycher-reviews__arrow--prev {
    left: -4px;
  }
  .neycher-reviews__arrow--next {
    right: -4px;
  }
}
{% endstylesheet %}

