<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} ingredients-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="ingredients-section__heading h3">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="ingredients-section__grid">
      {%- for block in section.blocks -%}
        <div class="ingredients-section__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="ingredients-section__image">
              {{ block.settings.image | image_url: width: 200 | image_tag: width: 80, height: 80, alt: block.settings.title, class: 'ingredients-section__img', loading: 'lazy' }}
            </div>
          {%- else -%}
            <div class="ingredients-section__image ingredients-section__image--placeholder">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="ingredients-section__title h6">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="ingredients-section__description">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .ingredients-section__heading {
    margin: 0 0 32px;
  }

  .ingredients-section__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media screen and (min-width: 750px) {
    .ingredients-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .ingredients-section__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .ingredients-section__card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ingredients-section__image {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ingredients-section__image--placeholder {
    background: rgb(var(--color-border-rgb) / 10%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ingredients-section__image--placeholder svg {
    width: 32px;
    height: 32px;
    opacity: 0.3;
  }

  .ingredients-section__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ingredients-section__title {
    margin: 0;
  }

  .ingredients-section__description {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ingredients grid",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Science-backed ingredients"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 48
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hyaluronic Acid"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Deeply hydrates and retains moisture for long-lasting comfort."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredients grid",
      "category": "t:categories.product",
      "blocks": [
        { "type": "ingredient", "settings": { "title": "Hyaluronic Acid", "description": "Deeply hydrates and retains moisture for long-lasting comfort." } },
        { "type": "ingredient", "settings": { "title": "Vitamin A", "description": "Supports cell renewal and tissue repair for healthier skin." } },
        { "type": "ingredient", "settings": { "title": "Vitamin E", "description": "Protects against oxidative stress and soothes irritation." } },
        { "type": "ingredient", "settings": { "title": "Lactic Acid", "description": "Maintains optimal pH balance for vaginal health." } }
      ]
    }
  ]
}
{% endschema %}
