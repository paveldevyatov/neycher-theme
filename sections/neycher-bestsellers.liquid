<section class="neycher-bestsellers n-section">
  <div class="n-section-header">
    <h2 class="n-title-section">Bestsellers</h2>
    <a href="/collections/all" class="n-btn-outline">Shop All <span>&rarr;</span></a>
  </div>
  <div class="neycher-bestsellers__scroll">
    <div class="neycher-bestsellers__grid">
      {%- assign bestseller_handles = "goodbye-dryness-bundle,yeast-away,bv-away,vaginal-moisturizer" | split: "," -%}
      {%- assign bestseller_images = "product-goodbye-dryness-bundle.webp,product-yeast-away.webp,product-bv-away.webp,product-vaginal-moisturizer.webp" | split: "," -%}
      {%- assign bestseller_names = '"BV Away + Vaginal Synbiotic" Bundle,Yeast Away,BV Away,Vaginal Moisturizer' | split: "," -%}
      {%- assign bestseller_prices = "$22.99,$22.99,$22.99,$22.99" | split: "," -%}
      {%- assign bestseller_descs = "Three-step system targeting BV symptoms and prevention,Anti-fungal herbal formulation soothes yeast-related irritation,Instantly banish odor and bacterial vaginosis-related symptoms,Ultra-hydrating formula restores comfort and natural vaginal moisture" | split: "," -%}

      {%- for i in (0..3) -%}
        {%- assign bs_product = all_products[bestseller_handles[i]] -%}
        <div class="neycher-bestsellers__card">
          <div class="neycher-bestsellers__img-wrap">
            <a href="/products/{{ bestseller_handles[i] }}" class="neycher-bestsellers__img-link">
              <img src="{{ bestseller_images[i] | asset_url }}" alt="{{ bestseller_names[i] }}" loading="lazy" width="400" height="400">
            </a>
            <a href="/products/{{ bestseller_handles[i] }}" class="n-cart-btn neycher-bestsellers__cart-btn" aria-label="Add to cart">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
              </svg>
            </a>
          </div>
          <div class="neycher-bestsellers__info">
            <a href="/products/{{ bestseller_handles[i] }}" class="n-product-name">{{ bestseller_names[i] }}</a>
            <div class="n-rating">
              <img src="{{ 'rating-stars.svg' | asset_url }}" alt="5.0 stars" width="80" height="16">
              <span>{{ bs_product.metafields.custom.rating | default: '5.0' }} ({{ bs_product.metafields.custom.reviews_count | default: '0' }})</span>
            </div>
            <p class="n-product-desc">{{ bestseller_descs[i] }}</p>
            <div class="n-product-price">Starting at {{ bestseller_prices[i] }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-bestsellers__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.neycher-bestsellers__scroll::-webkit-scrollbar {
  display: none;
}
.neycher-bestsellers__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.neycher-bestsellers__card {
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.neycher-bestsellers__img-wrap {
  position: relative;
  margin-bottom: 14px;
}
.neycher-bestsellers__img-link {
  display: block;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: var(--n-radius-md);
  background: var(--n-color-bg-alt);
}
.neycher-bestsellers__img-link img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.neycher-bestsellers__cart-btn {
  position: absolute;
  bottom: 12px;
  right: 12px;
}
.neycher-bestsellers__info {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.neycher-bestsellers .n-product-price {
  margin-top: 4px;
}
@media screen and (max-width: 999px) {
  .neycher-bestsellers__grid {
    grid-template-columns: repeat(4, 280px);
  }
}
@media screen and (max-width: 749px) {
  .neycher-bestsellers__grid {
    grid-template-columns: repeat(4, 240px);
    gap: 16px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Bestsellers",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Bestsellers"
    }
  ]
}
{% endschema %}
