{%- comment -%} Comparison table — our product vs other brands {%- endcomment -%}
<section class="npdp-cmp">
  <div class="npdp-cmp__inner">
    {%- comment -%} Header: heading + product images {%- endcomment -%}
    <div class="npdp-cmp__header">
      <h2 class="npdp-cmp__heading">{{ section.settings.heading }}</h2>
      <div class="npdp-cmp__img-card npdp-cmp__img-card--ours">
        {%- if section.settings.our_image_asset != blank -%}
          <img src="{{ section.settings.our_image_asset | asset_url }}" alt="{{ section.settings.our_label | escape }}" loading="lazy">
        {%- elsif section.settings.our_image != blank -%}
          <img src="{{ section.settings.our_image | image_url: width: 500 }}" alt="{{ section.settings.our_label | escape }}" loading="lazy">
        {%- endif -%}
        <span class="npdp-cmp__img-label">{{ section.settings.our_label }}</span>
      </div>
      <div class="npdp-cmp__img-card npdp-cmp__img-card--theirs">
        {%- if section.settings.other_image_asset != blank -%}
          <img src="{{ section.settings.other_image_asset | asset_url }}" alt="{{ section.settings.other_label | escape }}" loading="lazy">
        {%- elsif section.settings.other_image != blank -%}
          <img src="{{ section.settings.other_image | image_url: width: 500 }}" alt="{{ section.settings.other_label | escape }}" loading="lazy">
        {%- endif -%}
        <span class="npdp-cmp__img-label">{{ section.settings.other_label }}</span>
      </div>
    </div>

    {%- comment -%} Table rows {%- endcomment -%}
    {%- for block in section.blocks -%}
      <div class="npdp-cmp__row" {{ block.shopify_attributes }}>
        <div class="npdp-cmp__cell npdp-cmp__cell--label">{{ block.settings.label }}</div>
        <div class="npdp-cmp__cell npdp-cmp__cell--ours">
          <svg class="npdp-cmp__icon" width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="11" fill="#1D2836"/><path d="M6.5 11l3 3 5.5-5.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>{{ block.settings.our_value }}</span>
        </div>
        <div class="npdp-cmp__cell npdp-cmp__cell--theirs">
          <svg class="npdp-cmp__icon" width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="11" fill="#E8E8E8"/><path d="M7.5 7.5l7 7M14.5 7.5l-7 7" stroke="#999" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span>{{ block.settings.other_value }}</span>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
.npdp-cmp {
  max-width: 1440px;
  margin: 0 auto;
  padding: 80px 60px;
}
.npdp-cmp__inner {
  max-width: 100%;
}

/* Shared 3-column grid */
.npdp-cmp__header,
.npdp-cmp__row {
  display: grid;
  grid-template-columns: 1.2fr 1.4fr 1.4fr;
  gap: 24px;
  align-items: center;
}

/* Header */
.npdp-cmp__header {
  align-items: end;
  margin-bottom: 8px;
}
.npdp-cmp__heading {
  font-size: 42px;
  font-weight: 400;
  color: var(--n-color-heading);
  margin: 0;
  line-height: 1.08;
  padding-right: 20px;
}
.npdp-cmp__img-card {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  aspect-ratio: 4 / 3;
}
.npdp-cmp__img-card--ours {
  background: #2a3040;
}
.npdp-cmp__img-card--theirs {
  background: #e8e8e8;
}
.npdp-cmp__img-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.npdp-cmp__img-label {
  position: absolute;
  top: 14px;
  left: 14px;
  font-size: 13px;
  font-weight: 500;
  line-height: 1.3;
  max-width: 130px;
}
.npdp-cmp__img-card--ours .npdp-cmp__img-label {
  color: #fff;
}
.npdp-cmp__img-card--theirs .npdp-cmp__img-label {
  color: var(--n-color-heading);
}

/* Table rows */
.npdp-cmp__row {
  padding: 22px 0;
  border-bottom: 1px solid #eee;
}
.npdp-cmp__row:first-of-type {
  border-top: 1px solid #eee;
}
.npdp-cmp__cell--label {
  font-size: 15px;
  font-weight: 500;
  color: var(--n-color-heading);
}
.npdp-cmp__cell--ours,
.npdp-cmp__cell--theirs {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 14px;
  line-height: 1.5;
}
.npdp-cmp__cell--ours {
  color: var(--n-color-heading);
}
.npdp-cmp__cell--theirs {
  color: var(--n-color-muted);
}
.npdp-cmp__icon {
  flex-shrink: 0;
  margin-top: 1px;
}

/* Tablet */
@media screen and (max-width: 999px) {
  .npdp-cmp {
    padding: 60px 24px;
  }
  .npdp-cmp__header {
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 16px;
  }
  .npdp-cmp__header .npdp-cmp__heading {
    font-size: 32px;
    padding-right: 0;
  }
  /* Stack images side by side under heading */
  .npdp-cmp__header {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .npdp-cmp__heading {
    width: 100%;
    margin-bottom: 8px;
  }
  .npdp-cmp__img-card {
    flex: 1;
    min-width: 0;
  }
  .npdp-cmp__row {
    grid-template-columns: 0.8fr 1.1fr 1.1fr;
    gap: 16px;
    padding: 18px 0;
  }
}

/* Mobile */
@media screen and (max-width: 749px) {
  .npdp-cmp {
    padding: 48px 16px;
  }
  .npdp-cmp__heading {
    font-size: 26px;
  }
  .npdp-cmp__img-card {
    aspect-ratio: 4 / 3;
  }
  .npdp-cmp__img-label {
    font-size: 11px;
    top: 10px;
    left: 10px;
    max-width: 90px;
  }
  .npdp-cmp__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 20px 0;
  }
  .npdp-cmp__cell--label {
    grid-column: 1 / -1;
    font-size: 14px;
    font-weight: 600;
  }
  .npdp-cmp__cell--ours,
  .npdp-cmp__cell--theirs {
    font-size: 13px;
    gap: 8px;
    padding-left: 0;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "PDP Comparison",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "We're not like other brands" },
    { "type": "image_picker", "id": "our_image", "label": "Our product image" },
    { "type": "text", "id": "our_image_asset", "label": "Our image asset filename", "info": "Overrides image picker" },
    { "type": "text", "id": "our_label", "label": "Our label", "default": "Our Vaginal Suppositories" },
    { "type": "image_picker", "id": "other_image", "label": "Other brand image" },
    { "type": "text", "id": "other_image_asset", "label": "Other image asset filename", "info": "Overrides image picker" },
    { "type": "text", "id": "other_label", "label": "Other label", "default": "Other Brands" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        { "type": "text", "id": "label", "label": "Row label", "default": "Ingredients" },
        { "type": "text", "id": "our_value", "label": "Our value", "info": "Use 'yes', 'no', 'none', or custom text" },
        { "type": "text", "id": "other_value", "label": "Their value", "info": "Use 'yes', 'no', 'none', or custom text" }
      ]
    }
  ],
  "presets": [{ "name": "PDP Comparison" }]
}
{% endschema %}
