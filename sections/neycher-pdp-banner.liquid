{%- comment -%} Full-width banner with text + bundle card overlay {%- endcomment -%}
{%- assign banner_product = all_products[section.settings.bundle_handle] -%}

<section class="npdp-banner">
  <div class="npdp-banner__inner">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1440 }}" alt="" class="npdp-banner__bg" width="1440" height="560" loading="lazy">
    {%- endif -%}
    <div class="npdp-banner__content">
      <h2 class="npdp-banner__heading">{{ section.settings.heading }}</h2>
    </div>
    {%- if banner_product != blank -%}
      <a href="{{ banner_product.url }}" class="npdp-banner__bundle">
        {%- if banner_product.featured_image -%}
          <img src="{{ banner_product.featured_image | image_url: width: 400 }}" alt="{{ banner_product.title | escape }}" class="npdp-banner__bundle-img" width="200" height="200" loading="lazy">
        {%- endif -%}
        <div class="npdp-banner__bundle-info">
          <span class="npdp-banner__bundle-name">{{ banner_product.title }}</span>
          <span class="npdp-banner__bundle-price">Starting at {{ banner_product.price | money }}</span>
        </div>
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.npdp-banner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 60px;
}
.npdp-banner__inner {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  min-height: 420px;
  display: flex;
  align-items: flex-end;
}
.npdp-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.npdp-banner__content {
  position: relative;
  z-index: 1;
  padding: 48px 56px;
  flex: 1;
}
.npdp-banner__heading {
  font-size: 42px;
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.15;
  max-width: 380px;
}
.npdp-banner__bundle {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 16px;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(8px);
  border-radius: 12px;
  padding: 16px;
  margin: 48px 56px 48px 0;
  text-decoration: none;
  min-width: 280px;
}
.npdp-banner__bundle:hover {
  background: #fff;
}
.npdp-banner__bundle-img {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 8px;
  flex-shrink: 0;
}
.npdp-banner__bundle-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.npdp-banner__bundle-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--n-color-heading);
  line-height: 1.3;
}
.npdp-banner__bundle-price {
  font-size: 14px;
  color: var(--n-color-muted);
}
@media screen and (max-width: 999px) {
  .npdp-banner {
    padding: 0 24px;
  }
  .npdp-banner__inner {
    flex-direction: column;
    align-items: stretch;
    min-height: 360px;
  }
  .npdp-banner__content {
    padding: 32px;
  }
  .npdp-banner__heading {
    font-size: 32px;
  }
  .npdp-banner__bundle {
    margin: 0 32px 32px;
  }
}
@media screen and (max-width: 749px) {
  .npdp-banner {
    padding: 0 16px;
  }
  .npdp-banner__content {
    padding: 24px;
  }
  .npdp-banner__heading {
    font-size: 26px;
  }
  .npdp-banner__bundle {
    margin: 0 24px 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "PDP Banner",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Holistic vaginal health starts here." },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "bundle_handle", "label": "Bundle product handle", "info": "Handle of the bundle product to display" }
  ],
  "presets": [{ "name": "PDP Banner" }]
}
{% endschema %}
