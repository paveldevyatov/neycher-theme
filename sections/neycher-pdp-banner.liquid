{%- comment -%} Full-width banner with text + product card overlay {%- endcomment -%}
{%- assign banner_product = all_products[section.settings.bundle_handle] -%}

<section class="npdp-banner">
  <div class="npdp-banner__inner">
    {%- if section.settings.image_asset != blank -%}
      <img src="{{ section.settings.image_asset | asset_url }}" alt="" class="npdp-banner__bg" width="1440" height="560" loading="lazy">
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1440 }}" alt="" class="npdp-banner__bg" width="1440" height="560" loading="lazy">
    {%- endif -%}

    <div class="npdp-banner__content">
      <h2 class="npdp-banner__heading">{{ section.settings.heading }}</h2>
    </div>

    {%- if banner_product != blank -%}
      <div class="npdp-banner__card">
        <a href="{{ banner_product.url }}" class="npdp-banner__card-img-link">
          {%- if banner_product.featured_image -%}
            <img src="{{ banner_product.featured_image | image_url: width: 600 }}" alt="{{ banner_product.title | escape }}" loading="lazy" width="300" height="300">
          {%- endif -%}
        </a>
        <div class="npdp-banner__card-info">
          <div class="npdp-banner__card-top">
            <a href="{{ banner_product.url }}" class="npdp-banner__card-name">{{ banner_product.title }}</a>
            <a href="{{ banner_product.url }}" class="n-cart-btn n-cart-btn--muted" aria-label="View product">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
              </svg>
            </a>
          </div>
          <div class="n-rating">
            <img src="{{ 'rating-stars.svg' | asset_url }}" alt="stars" width="80" height="16">
            <span>{{ banner_product.metafields.custom.rating | default: '4.0' }} ({{ banner_product.metafields.custom.reviews_count | default: '12' }})</span>
          </div>
          {%- if section.settings.description != blank -%}
            <p class="n-product-desc">{{ section.settings.description }}</p>
          {%- elsif banner_product.description != blank -%}
            <p class="n-product-desc">{{ banner_product.description | strip_html | truncate: 80 }}</p>
          {%- endif -%}
          <div class="n-product-price">Starting at {{ banner_product.price | money }}</div>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.npdp-banner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 60px;
}
.npdp-banner__inner {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  min-height: 520px;
  display: flex;
  align-items: center;
}
.npdp-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.npdp-banner__content {
  position: relative;
  z-index: 1;
  padding: 48px 56px;
  flex: 1;
}
.npdp-banner__heading {
  font-size: 42px;
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.15;
  max-width: 420px;
}

/* Product card with glassmorphism */
.npdp-banner__card {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-radius: 16px;
  margin: 40px 56px 40px 0;
  width: 340px;
  flex-shrink: 0;
  overflow: hidden;
}
.npdp-banner__card-img-link {
  display: block;
  padding: 24px 24px 16px;
}
.npdp-banner__card-img-link img {
  width: 100%;
  height: auto;
  object-fit: contain;
  border-radius: 8px;
}
.npdp-banner__card-info {
  padding: 0 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.npdp-banner__card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}
.npdp-banner__card-name {
  font-size: 18px;
  font-weight: 500;
  color: var(--n-color-heading);
  text-decoration: none;
  line-height: 1.3;
}
.npdp-banner__card-name:hover {
  text-decoration: underline;
}
.npdp-banner__card .n-product-price {
  margin-top: 4px;
}

@media screen and (max-width: 999px) {
  .npdp-banner {
    padding: 0 24px;
  }
  .npdp-banner__inner {
    flex-direction: column;
    align-items: stretch;
    min-height: auto;
  }
  .npdp-banner__content {
    padding: 40px 32px 24px;
  }
  .npdp-banner__heading {
    font-size: 32px;
  }
  .npdp-banner__card {
    width: auto;
    margin: 0 32px 32px;
    max-width: 340px;
  }
}
@media screen and (max-width: 749px) {
  .npdp-banner {
    padding: 0 16px;
  }
  .npdp-banner__content {
    padding: 32px 24px 20px;
  }
  .npdp-banner__heading {
    font-size: 26px;
  }
  .npdp-banner__card {
    margin: 0 24px 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "PDP Banner",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get fearlessly intimate." },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "image_asset", "label": "Background image asset filename", "info": "Overrides image picker" },
    { "type": "text", "id": "bundle_handle", "label": "Product handle", "info": "Handle of the product to display in card" },
    { "type": "text", "id": "description", "label": "Product description", "info": "Overrides product description" }
  ],
  "presets": [{ "name": "PDP Banner" }]
}
{% endschema %}
