<section class="neycher-journal n-section">
  <div class="n-section-header">
    <h2 class="n-title-section">Journal</h2>
    <div class="neycher-journal__controls">
      <button class="neycher-journal__arrow" data-journal-prev aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 14l-5-5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="neycher-journal__arrow" data-journal-next aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <a href="/blogs/journal" class="n-btn-outline">Read Journal <span>&rarr;</span></a>
    </div>
  </div>
  <div class="neycher-journal__scroll n-scroll-container" data-journal-scroll>
    <div class="neycher-journal__grid">
      <a href="/blogs/journal/how-to-fix-dryness-from-birth-control" class="neycher-journal__card">
        <div class="neycher-journal__img">
          <img src="{{ 'journal-1.jpg' | asset_url }}" alt="How to Fix Dryness from Birth Control?" loading="lazy" width="400" height="260">
        </div>
        <span class="neycher-journal__tag">Health</span>
        <h3 class="neycher-journal__card-title">How to Fix Dryness from Birth Control?</h3>
      </a>
      <a href="/blogs/journal/how-to-use-vaginal-suppositories" class="neycher-journal__card">
        <div class="neycher-journal__img">
          <img src="{{ 'journal-2.jpg' | asset_url }}" alt="How to Use Vaginal Suppositories" loading="lazy" width="400" height="260">
        </div>
        <span class="neycher-journal__tag">Wellness</span>
        <h3 class="neycher-journal__card-title">How to Use Vaginal Suppositories</h3>
      </a>
      <a href="/blogs/journal/is-vaginal-dryness-a-sign-of-pregnancy" class="neycher-journal__card">
        <div class="neycher-journal__img">
          <img src="{{ 'journal-3.jpg' | asset_url }}" alt="Is Vaginal Dryness a Sign of Pregnancy?" loading="lazy" width="400" height="260">
        </div>
        <span class="neycher-journal__tag">Science</span>
        <h3 class="neycher-journal__card-title">Is Vaginal Dryness a Sign of Pregnancy?</h3>
      </a>
      <a href="/blogs/journal/does-your-labia-disappear-in-menopause" class="neycher-journal__card">
        <div class="neycher-journal__img">
          <img src="{{ 'journal-4.jpg' | asset_url }}" alt="Does Your Labia Disappear In Menopause?" loading="lazy" width="400" height="260">
        </div>
        <span class="neycher-journal__tag">Wellness</span>
        <h3 class="neycher-journal__card-title">Does Your Labia Disappear In Menopause?</h3>
      </a>
      <a href="/blogs/journal/bacterial-vaginosis-vs-yeast-infection" class="neycher-journal__card">
        <div class="neycher-journal__img">
          <img src="{{ 'journal-5.jpg' | asset_url }}" alt="Bacterial Vaginosis vs Yeast Infection" loading="lazy" width="400" height="260">
        </div>
        <span class="neycher-journal__tag">Menopause</span>
        <h3 class="neycher-journal__card-title">Bacterial Vaginosis vs Yeast Infection</h3>
      </a>
    </div>
  </div>
  <div class="n-scroll-progress"><div class="n-scroll-progress__bar"></div></div>
</section>

<script>
  (function() {
    var scrollEl = document.querySelector('[data-journal-scroll]');
    if (!scrollEl) return;
    var section = scrollEl.closest('.neycher-journal');
    var prevBtn = section.querySelector('[data-journal-prev]');
    var nextBtn = section.querySelector('[data-journal-next]');
    var grid = scrollEl.querySelector('.neycher-journal__grid');

    function getStep() {
      var card = grid.querySelector('.neycher-journal__card');
      if (!card) return 280;
      var gap = parseInt(getComputedStyle(grid).columnGap) || 16;
      return card.offsetWidth + gap;
    }

    nextBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: getStep(), behavior: 'smooth' });
    });
    prevBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });
  })();
</script>

{% stylesheet %}
/* Controls */
.neycher-journal__controls {
  display: flex;
  align-items: center;
  gap: 12px;
}
.neycher-journal__arrow {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--n-color-border);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--n-color-heading);
}
.neycher-journal__arrow:hover {
  border-color: var(--n-color-heading);
}

/* Scroll */
.neycher-journal__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  scroll-snap-type: x mandatory;
}
.neycher-journal__scroll::-webkit-scrollbar {
  display: none;
}

/* Grid */
.neycher-journal__grid {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc(25% - 15px);
  gap: 20px;
}

/* Card */
.neycher-journal__card {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-width: 0;
  scroll-snap-align: start;
}
.neycher-journal__img {
  aspect-ratio: 3 / 4;
  overflow: hidden;
  border-radius: var(--n-radius-md);
  background: var(--n-color-bg-alt);
}
.neycher-journal__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.neycher-journal__tag {
  font-family: var(--n-font);
  font-size: 11px;
  font-weight: 500;
  color: var(--n-color-body);
  text-transform: uppercase;
  letter-spacing: 1px;
}
.neycher-journal__card-title {
  font-family: var(--n-font);
  font-size: 15px;
  font-weight: 500;
  color: var(--n-color-heading);
  margin: 0;
  line-height: 1.3;
}
.neycher-journal__card:hover .neycher-journal__card-title {
  text-decoration: underline;
}

@media screen and (max-width: 999px) {
  .neycher-journal__grid {
    grid-auto-columns: calc(33.333% - 14px);
  }
}
@media screen and (max-width: 749px) {
  .neycher-journal__grid {
    grid-auto-columns: 240px;
    gap: 16px;
  }
}
{% endstylesheet %}

