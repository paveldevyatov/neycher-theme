<section
  class="neycher-journal n-section"
  style="
    --journal-bg: {{ section.settings.bg_color }};
    --journal-heading-color: {{ section.settings.heading_color }};
    --journal-text-color: {{ section.settings.text_color }};
    --journal-card-radius: {{ section.settings.card_radius }}px;
    --journal-cols: {{ section.settings.cards_per_row }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  "
>
  <div class="n-section-header">
    <h2 class="n-title-section" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    {%- if section.settings.link_url != blank -%}
      <a href="{{ section.settings.link_url }}" class="n-btn-outline">{{ section.settings.link_text }} <span>&rarr;</span></a>
    {%- endif -%}
  </div>
  <div class="neycher-journal__slider">
    <button class="neycher-journal__arrow neycher-journal__arrow--prev" data-journal-prev aria-label="Previous">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 14l-5-5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="neycher-journal__arrow neycher-journal__arrow--next" data-journal-next aria-label="Next">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="neycher-journal__scroll n-scroll-container" data-journal-scroll>
    <div class="neycher-journal__grid">
      {%- for block in section.blocks -%}
        {%- assign card_href = block.settings.link | default: '#' -%}
        <a href="{{ card_href }}" class="neycher-journal__card" {{ block.shopify_attributes }}>
          <div class="neycher-journal__img">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  width: 400,
                  height: 260,
                  alt: block.settings.title
              }}
            {%- elsif block.settings.image_asset != blank -%}
              <img
                src="{{ block.settings.image_asset | asset_url }}"
                alt="{{ block.settings.title }}"
                loading="lazy"
                width="400"
                height="260"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'neycher-journal__placeholder' }}
            {%- endif -%}
          </div>
          <span class="neycher-journal__tag" style="color: {{ section.settings.text_color }};">{{ block.settings.tag }}</span>
          <h3 class="neycher-journal__card-title" style="color: {{ section.settings.heading_color }};">{{ block.settings.title }}</h3>
        </a>
      {%- endfor -%}
    </div>
    </div>
  </div>
  <div class="n-scroll-progress"><div class="n-scroll-progress__bar"></div></div>
</section>

<script>
  (function() {
    var scrollEl = document.querySelector('[data-journal-scroll]');
    if (!scrollEl) return;
    var section = scrollEl.closest('.neycher-journal');
    var prevBtn = section.querySelector('[data-journal-prev]');
    var nextBtn = section.querySelector('[data-journal-next]');
    var grid = scrollEl.querySelector('.neycher-journal__grid');

    function getStep() {
      var card = grid.querySelector('.neycher-journal__card');
      if (!card) return 280;
      var gap = parseInt(getComputedStyle(grid).columnGap) || 16;
      return card.offsetWidth + gap;
    }

    nextBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: getStep(), behavior: 'smooth' });
    });
    prevBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });

    var progressBar = section.querySelector('.n-scroll-progress__bar');
    function updateProgress() {
      if (!progressBar) return;
      var maxScroll = scrollEl.scrollWidth - scrollEl.clientWidth;
      if (maxScroll <= 0) {
        progressBar.style.width = '100%';
        return;
      }
      var ratio = scrollEl.clientWidth / scrollEl.scrollWidth;
      var pos = scrollEl.scrollLeft / maxScroll;
      var barW = Math.max(ratio * 100, 10);
      var maxLeft = 100 - barW;
      progressBar.style.width = barW + '%';
      progressBar.style.transform = 'translateX(' + (pos * maxLeft / barW * 100) + '%)';
    }
    scrollEl.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  })();
</script>

{% stylesheet %}
/* Slider wrapper */
.neycher-journal__slider {
  position: relative;
}
.neycher-journal__arrow {
  position: absolute;
  top: 35%;
  transform: translateY(-50%);
  z-index: 2;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--n-color-border);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--n-color-heading);
}
.neycher-journal__arrow--prev {
  left: -20px;
}
.neycher-journal__arrow--next {
  right: -20px;
}
.neycher-journal__arrow:hover {
  border-color: var(--n-color-heading);
}

/* Scroll */
.neycher-journal__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  scroll-snap-type: x mandatory;
}
.neycher-journal__scroll::-webkit-scrollbar {
  display: none;
}

/* Grid */
.neycher-journal__grid {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc(100% / var(--journal-cols) - (20px * (var(--journal-cols) - 1) / var(--journal-cols)));
  gap: 20px;
}

/* Card */
.neycher-journal__card {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-width: 0;
  scroll-snap-align: start;
}
.neycher-journal__img {
  aspect-ratio: 3 / 4;
  overflow: hidden;
  border-radius: var(--journal-card-radius, var(--n-radius-md));
  background: var(--n-color-bg-alt);
}
.neycher-journal__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.neycher-journal__placeholder {
  width: 100%;
  height: 100%;
}
.neycher-journal__tag {
  font-family: var(--n-font);
  font-size: 11px;
  font-weight: 500;
  color: var(--journal-text-color, var(--n-color-body));
  text-transform: uppercase;
  letter-spacing: 1px;
}
.neycher-journal__card-title {
  font-family: var(--n-font);
  font-size: 15px;
  font-weight: 500;
  color: var(--journal-heading-color, var(--n-color-heading));
  margin: 0;
  line-height: 1.3;
}
.neycher-journal__card:hover .neycher-journal__card-title {
  text-decoration: underline;
}

@media screen and (max-width: 999px) {
  .neycher-journal__grid {
    grid-auto-columns: calc(33.333% - 14px);
  }
}
@media screen and (max-width: 749px) {
  .neycher-journal__grid {
    grid-auto-columns: 240px;
    gap: 16px;
  }
  .neycher-journal__arrow {
    width: 32px;
    height: 32px;
  }
  .neycher-journal__arrow svg {
    width: 14px;
    height: 14px;
  }
  .neycher-journal__arrow--prev {
    left: -4px;
  }
  .neycher-journal__arrow--next {
    right: -4px;
  }
}
{% endstylesheet %}

