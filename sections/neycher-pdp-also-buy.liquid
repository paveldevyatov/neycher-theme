{%- comment -%} People also buy — product recommendations {%- endcomment -%}
<section class="npdp-also n-section" style="--also-bg: {{ section.settings.bg_color }}; --also-heading: {{ section.settings.heading_color }}; --also-text: {{ section.settings.text_color }}; --also-radius: {{ section.settings.card_radius }}px; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.bg_color }};">
  <div class="n-section-header">
    <h2 class="n-title-section" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    {%- if section.settings.link_url != blank -%}
      <a href="{{ section.settings.link_url }}" class="n-btn-outline">{{ section.settings.link_text }} <span>&rarr;</span></a>
    {%- endif -%}
  </div>
  <div class="npdp-also__slider">
    <button class="npdp-also__arrow npdp-also__arrow--prev" data-also-prev aria-label="Previous">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 14l-5-5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="npdp-also__arrow npdp-also__arrow--next" data-also-next aria-label="Next">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="npdp-also__scroll n-scroll-container" data-also-scroll>
    <div class="npdp-also__grid">
      {%- for block in section.blocks -%}
        {%- assign p = block.settings.product -%}
        {%- if p != blank -%}
          <div class="npdp-also__card" {{ block.shopify_attributes }}>
            <div class="npdp-also__img-wrap">
              <a href="{{ p.url }}" class="npdp-also__img-link">
                {%- if p.featured_image != blank -%}
                  <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title | escape }}" loading="lazy" width="300" height="300">
                {%- endif -%}
              </a>
              <a href="{{ p.url }}" class="n-cart-btn npdp-also__cart-btn" aria-label="View {{ p.title }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
                </svg>
              </a>
            </div>
            <div class="npdp-also__info">
              <a href="{{ p.url }}" class="n-product-name">{{ p.title }}</a>
              <div class="n-rating">
                <img src="{{ 'rating-stars.svg' | asset_url }}" alt="5.0 stars" width="80" height="16">
                <span>5.0 (12)</span>
              </div>
              {%- if block.settings.description != blank -%}
                <p class="n-product-desc">{{ block.settings.description }}</p>
              {%- elsif p.description != blank -%}
                <p class="n-product-desc">{{ p.description | strip_html | truncate: 80 }}</p>
              {%- endif -%}
              <div class="n-product-price">Starting at {{ p.price | money }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    </div>
  </div>
  <div class="n-scroll-progress"><div class="n-scroll-progress__bar"></div></div>
</section>

<script>
  (function() {
    var scrollEl = document.querySelector('[data-also-scroll]');
    if (!scrollEl) return;
    var prevBtn = scrollEl.closest('.npdp-also').querySelector('[data-also-prev]');
    var nextBtn = scrollEl.closest('.npdp-also').querySelector('[data-also-next]');
    var grid = scrollEl.querySelector('.npdp-also__grid');

    function getStep() {
      var card = grid.querySelector('.npdp-also__card');
      if (!card) return 300;
      var gap = parseInt(getComputedStyle(grid).columnGap) || 20;
      return card.offsetWidth + gap;
    }

    nextBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: getStep(), behavior: 'smooth' });
    });
    prevBtn.addEventListener('click', function() {
      scrollEl.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });

    var progressBar = scrollEl.closest('.npdp-also').querySelector('.n-scroll-progress__bar');
    function updateProgress() {
      if (!progressBar) return;
      var maxScroll = scrollEl.scrollWidth - scrollEl.clientWidth;
      if (maxScroll <= 0) {
        progressBar.style.width = '100%';
        return;
      }
      var ratio = scrollEl.clientWidth / scrollEl.scrollWidth;
      var pos = scrollEl.scrollLeft / maxScroll;
      var barW = Math.max(ratio * 100, 10);
      var maxLeft = 100 - barW;
      progressBar.style.width = barW + '%';
      progressBar.style.transform = 'translateX(' + (pos * maxLeft / barW * 100) + '%)';
    }
    scrollEl.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  })();
</script>

{% stylesheet %}
/* Slider wrapper */
.npdp-also__slider {
  position: relative;
}
.npdp-also__arrow {
  position: absolute;
  top: 35%;
  transform: translateY(-50%);
  z-index: 2;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--n-color-border);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--n-color-heading);
}
.npdp-also__arrow--prev {
  left: -20px;
}
.npdp-also__arrow--next {
  right: -20px;
}
.npdp-also__arrow:hover {
  border-color: var(--n-color-heading);
}

/* Scroll container */
.npdp-also__scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  scroll-snap-type: x mandatory;
}
.npdp-also__scroll::-webkit-scrollbar {
  display: none;
}

/* Grid */
.npdp-also__grid {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc(25% - 15px);
  gap: 20px;
}

/* Cards */
.npdp-also__card {
  display: flex;
  flex-direction: column;
  min-width: 0;
  scroll-snap-align: start;
}
.npdp-also__img-wrap {
  position: relative;
  margin-bottom: 14px;
}
.npdp-also__img-link {
  display: block;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: var(--also-radius, var(--n-radius-md));
  background: var(--n-color-bg-alt);
}
.npdp-also__img-link img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.npdp-also__cart-btn {
  position: absolute;
  bottom: 12px;
  right: 12px;
}
.npdp-also__info {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.npdp-also .n-product-price {
  margin-top: 4px;
}

@media screen and (max-width: 999px) {
  .npdp-also__grid {
    grid-auto-columns: calc(33.333% - 14px);
  }
}
@media screen and (max-width: 749px) {
  .npdp-also__grid {
    grid-auto-columns: 240px;
    gap: 16px;
  }
  .npdp-also__arrow {
    width: 32px;
    height: 32px;
  }
  .npdp-also__arrow svg {
    width: 14px;
    height: 14px;
  }
  .npdp-also__arrow--prev {
    left: -4px;
  }
  .npdp-also__arrow--next {
    right: -4px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "PDP Also Buy",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "People also buy" },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Shop All" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#1D2836" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#555555" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "default": 60, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "default": 60, "unit": "px" },
    { "type": "range", "id": "card_radius", "label": "Card image radius", "min": 0, "max": 24, "step": 2, "default": 12, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "description", "label": "Custom description", "info": "Overrides product description" }
      ]
    }
  ],
  "presets": [{ "name": "PDP Also Buy" }]
}
{% endschema %}
