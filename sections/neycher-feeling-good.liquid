<section
  class="neycher-fg"
  style="
    --nfg-pt: {{ section.settings.padding_top }}px;
    --nfg-pb: {{ section.settings.padding_bottom }}px;
    --nfg-radius: {{ section.settings.border_radius }}px;
    --nfg-min-height: {{ section.settings.min_height }}px;
    --nfg-heading-color: {{ section.settings.heading_color }};
    --nfg-overlay: {{ section.settings.overlay_color }};
  "
>
  <div class="neycher-fg__inner">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1440 }}" alt="Feeling Good background" class="neycher-fg__bg" width="1440" height="400" loading="lazy">
    {%- elsif section.settings.image_asset != blank -%}
      <img src="{{ section.settings.image_asset | asset_url }}" alt="Feeling Good background" class="neycher-fg__bg" width="1440" height="400" loading="lazy">
    {%- else -%}
      <img src="{{ 'dna.jpeg' | asset_url }}" alt="Feeling Good background" class="neycher-fg__bg" width="1440" height="400" loading="lazy">
    {%- endif -%}
    {%- if section.settings.overlay_color != 'rgba(0,0,0,0)' and section.settings.overlay_color != blank -%}
      <div class="neycher-fg__overlay"></div>
    {%- endif -%}
    <div class="neycher-fg__content">
      <h2 class="n-title-display neycher-fg__heading">{{ section.settings.heading }}</h2>
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-fg {
  padding: var(--nfg-pt, 0) 60px var(--nfg-pb, 48px);
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-fg__inner {
  position: relative;
  border-radius: var(--nfg-radius, 16px);
  overflow: hidden;
  min-height: var(--nfg-min-height, 280px);
  display: flex;
  align-items: center;
}
.neycher-fg__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.neycher-fg__overlay {
  position: absolute;
  inset: 0;
  background-color: var(--nfg-overlay, transparent);
  z-index: 1;
}
.neycher-fg__content {
  position: relative;
  z-index: 2;
  padding: 48px 56px;
}
.neycher-fg__heading {
  margin: 0;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 32px;
  font-weight: 400;
  line-height: 1.3;
  color: var(--nfg-heading-color, var(--n-color-heading));
}
@media screen and (max-width: 749px) {
  .neycher-fg {
    padding: var(--nfg-pt, 0) 16px var(--nfg-pb, 32px);
  }
  .neycher-fg__inner {
    min-height: 200px;
  }
  .neycher-fg__content {
    padding: 28px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Feeling Good",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Feeling Good is a<br>Science We've Mastered"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Image asset filename (fallback)",
      "info": "Asset filename fallback",
      "default": "dna.jpeg"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1D2836"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Image overlay color",
      "info": "Optional color overlay on image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height",
      "min": 200,
      "max": 500,
      "step": 20,
      "default": 280,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Neycher Feeling Good"
    }
  ]
}
{% endschema %}
