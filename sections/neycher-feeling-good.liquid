<section class="neycher-fg">
  <div class="neycher-fg__inner">
    <img src="{{ 'dna.jpeg' | asset_url }}" alt="DNA helix" class="neycher-fg__bg" width="1440" height="400" loading="lazy">
    <div class="neycher-fg__content">
      <h2 class="n-title-display neycher-fg__heading">Feeling Good is a<br>Science We've Mastered</h2>
    </div>
  </div>
</section>

{% stylesheet %}
.neycher-fg {
  padding: 0 60px 48px;
  max-width: 1440px;
  margin: 0 auto;
}
.neycher-fg__inner {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  min-height: 280px;
  display: flex;
  align-items: center;
}
.neycher-fg__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.neycher-fg__content {
  position: relative;
  z-index: 1;
  padding: 48px 56px;
}
.neycher-fg__heading {
  margin: 0;
  color: var(--n-color-heading);
}
@media screen and (max-width: 749px) {
  .neycher-fg {
    padding: 0 16px 32px;
  }
  .neycher-fg__inner {
    min-height: 200px;
  }
  .neycher-fg__content {
    padding: 28px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Neycher Feeling Good",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Feeling Good"
    }
  ]
}
{% endschema %}
