  "name": "Neycher Feeling Good",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Neycher Feeling Good"
    }
  ]
}
{% endschema %}
